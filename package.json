{
    "name": "webtrees-statistics",
    "version": "1.7.2-dev",
    "description": "SVG-based statistics charts for the webtrees genealogy application.",
    "keywords": [
        "webtrees",
        "module",
        "statistics",
        "chart"
    ],
    "type": "module",
    "homepage": "https://github.com/magicsunday/webtrees-statistics",
    "license": "GPL-3.0-or-later",
    "author": "Rico Sonntag <mail@ricosonntag.de>",
    "repository": {
        "type": "git",
        "url": "https://github.com/magicsunday/webtrees-statistics.git"
    },
    "scripts": {
        "prepare": "rollup --config rollup.config.js",
        "watch": "rollup --watch --config rollup.config.js",
        "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
        "lint": "biome lint --error-on-warnings resources/js/modules/",
        "lint:fix": "biome lint --fix --unsafe resources/js/modules/",
        "format": "biome format --write resources/js/modules/ resources/js/tests/",
        "format:check": "biome format resources/js/modules/ resources/js/tests/",
        "typecheck": "tsc --noEmit -p jsconfig.json"
    },
    "dependencies": {
        "@magicsunday/webtrees-chart-lib": "github:magicsunday/webtrees-chart-lib#1.16.1",
        "d3-array": "^3.2",
        "d3-axis": "^3.0",
        "d3-ease": "^3.0",
        "d3-fetch": "^3.0",
        "d3-geo": "^3.1",
        "d3-interpolate": "^3.0",
        "d3-sankey": "^0.12.3",
        "d3-scale": "^4.0",
        "d3-scale-chromatic": "^3.0",
        "d3-selection": "^3.0",
        "d3-shape": "^3.2",
        "d3-transition": "^3.0"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "testMatch": [
            "<rootDir>/resources/js/tests/**/*.test.js"
        ],
        "transform": {}
    },
    "overrides": {
        "js-yaml": "^4.2.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "@rollup/plugin-node-resolve": "^16.0",
        "@rollup/plugin-terser": "^1.0",
        "@types/d3-fetch": "^3.0.7",
        "@types/d3-geo": "^3.1.0",
        "@types/jest": "^30.0",
        "jest": "^30.0",
        "jest-environment-jsdom": "^30.0",
        "jscpd": "^5.0.9",
        "rollup": "^4.61",
        "rollup-plugin-license": "^3.7.1",
        "typescript": "^6.0.3"
    }
}

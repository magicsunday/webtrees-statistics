declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Model\LineChart\LineChartPayload;
use MagicSunday\Webtrees\Statistic\Statistic;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\DecadeBinCollapser;
use MagicSunday\Webtrees\Statistic\Support\Locale\DecadeName;
use MagicSunday\Webtrees\Statistic\View\Accent;
use MagicSunday\Webtrees\Statistic\View\Card;
use MagicSunday\Webtrees\Statistic\View\Component;
use MagicSunday\Webtrees\Statistic\View\Illustration;
use MagicSunday\Webtrees\Statistic\View\Section;
use MagicSunday\Webtrees\Statistic\View\Widget;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$totalIndividuals = $statistic->getTotalIndividuals();
$totalOccupations = $statistic->getTotalOccupations();
$totalReligions   = $statistic->getTotalReligions();
$topOccupations   = $statistic->getTopOccupations(10);
$topReligions     = $statistic->getTopReligions(10);
$treeRecords      = $statistic->getTreeRecords();

$occupationInheritance = $statistic->getOccupationInheritance(12);

$livingDeceased = $statistic->getTotalLivingDeceasedData();
$livingCount    = $livingDeceased[0]['value'] ?? 0;
$deceasedCount  = $livingDeceased[1]['value'] ?? 0;
$maritalData    = $statistic->getFamilyStatusData();

$cumulativeBirthsByDecade = $statistic->getCumulativeBirthsByDecade();
// The cumulative series is monotonically non-decreasing; its
// last entry is the running total at the latest visible decade,
// which equals array_sum(getBirthsByDecade()) by construction.
// Use it directly so the sub-headline can never drift from the
// chart, and to avoid a second identical SQL round-trip.
$cumulativeBirthsTotal = $cumulativeBirthsByDecade === [] ? 0 : end($cumulativeBirthsByDecade);
reset($cumulativeBirthsByDecade);

$cumulativeBirthsBinSize = DecadeBinCollapser::pickBinSize(count($cumulativeBirthsByDecade));
$cumulativeBirthsPlot    = DecadeBinCollapser::collapseCumulative($cumulativeBirthsByDecade);

$cumulativeBirthsCardSub = I18N::plural(
    '%s individual with a recorded birth year',
    '%s individuals with a recorded birth year',
    $cumulativeBirthsTotal,
    I18N::number($cumulativeBirthsTotal),
);

if ($cumulativeBirthsBinSize > 1) {
    $cumulativeBirthsCardSub .= ' — ' . I18N::translate(
        'aggregated into %s-decade bins for readability',
        I18N::number($cumulativeBirthsBinSize),
    );
}

$cumulativeBirthsPayload = LineChartPayload::singleSeries(
    seriesName: I18N::translate('Cumulative population'),
    countsByCategory: $cumulativeBirthsPlot,
    project: static function (int|string $decade, int|float $count) use ($cumulativeBirthsBinSize): array {
        $startDecade  = (int) $decade;
        $endDecade    = $startDecade + ($cumulativeBirthsBinSize - 1) * 10;
        $tooltipLabel = ($cumulativeBirthsBinSize === 1)
            ? I18N::translate('Up to the %s', DecadeName::for($startDecade))
            : I18N::translate('Up to the end of the %s', DecadeName::for($endDecade));

        return [
            'categoryLabel' => DecadeName::for($startDecade),
            'tooltipBody'   => I18N::plural('%s individual recorded', '%s individuals recorded', (int) $count, I18N::number($count)),
            'tooltipLabel'  => $tooltipLabel,
        ];
    },
);
?>
<div class="wt-stat-grid">
<?php
echo Section::create(I18N::translate('Who is recorded?'))
    ->withKicker(I18N::translate('Demographics'))
    ->withSub(I18N::translate('Sex, status, marital state'))
    ->render();

echo Card::for($module, I18N::translate('Sex'))
    ->withSub(I18N::plural('%s individual', '%s individuals', $totalIndividuals, I18N::number($totalIndividuals)))
    ->withEyebrow(I18N::translate('Distribution'))
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::People)
    ->withSpan(4)
    ->withoutFooter()
    ->withBodyHtml(
        Widget::donutChart($module, 'gender-donut-chart')
            ->withData($statistic->getTotalIndividualsData())
            ->with('centerLabel', I18N::translate('individuals'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Living or deceased'))
    ->withSub(I18N::plural('%s individual', '%s individuals', $totalIndividuals, I18N::number($totalIndividuals)))
    ->withEyebrow(I18N::translate('Status'))
    ->withAccent(Accent::Sage)
    ->withIllustration(Illustration::Candle)
    ->withSpan(4)
    ->withoutFooter()
    ->withBodyHtml(
        Component::liveDeadCard($module)
            ->with('living', $livingCount)
            ->with('deceased', $deceasedCount)
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Marital status'))
    ->withSub(I18N::translate('individuals without a recorded death'))
    ->withEyebrow(I18N::translate('Status'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Rings)
    ->withSpan(4)
    ->withoutFooter()
    ->withBodyHtml(
        Component::maritalCard($module)
            ->withData($maritalData)
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('The extremes of the tree'))
    ->withKicker(I18N::translate('Chronicle'))
    ->withSub(I18N::translate('Oldest, longest marriages, largest families · records that anchor the dataset'))
    ->render();

echo Card::for($module, I18N::translate('Tree records'))
    ->withSub(I18N::translate('Hall of fame across the whole tree'))
    ->withEyebrow(I18N::translate('Records'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Laurel)
    ->withSpan(12)
    ->withoutFooter()
    ->withBodyHtml(
        Component::recordsGrid($module)
            ->with('treeRecords', $treeRecords)
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('Occupation and confession'))
    ->withKicker(I18N::translate('Socio-economics'))
    ->withSub(I18N::translate('Occupational and religious affiliation of the recorded individuals'))
    ->render();

echo Card::for($module, I18N::translate('Common occupations'))
    ->withSub(
        $totalOccupations > 10
            ? I18N::translate('%s distinct occupations (top 10)', I18N::number($totalOccupations))
            : I18N::plural('%s distinct occupation', '%s distinct occupations', $totalOccupations, I18N::number($totalOccupations))
    )
    ->withEyebrow(I18N::translate('Demographics'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Craft)
    ->withSpan(6)
    ->withoutFooter()
    ->withBodyHtml(
        Component::progressList($module)
            ->with('class', 'progress-occupations')
            ->withData($topOccupations)
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Common religions'))
    ->withSub(
        $totalReligions > 10
            ? I18N::translate('%s distinct religions (top 10)', I18N::number($totalReligions))
            : I18N::plural('%s distinct religion', '%s distinct religions', $totalReligions, I18N::number($totalReligions))
    )
    ->withEyebrow(
        I18N::translate('Demographics')
    )
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::Chapel)
    ->withSpan(6)
    ->withoutFooter()
    ->withBodyHtml(
        Component::progressList($module)
        ->with('class', 'progress-religions')
        ->withData($topReligions)
        ->render()
    )
    ->render();

$occupationInheritanceExplanation = I18N::translate(
    'Each band links a father\'s occupation to the occupation of one of his sons. The band\'s thickness encodes the count: thicker bands mean more sons recorded in that trade after their father. Only sons whose father also has a recorded occupation are counted. Hover any band to see the exact father trade → son trade, the number of sons, and a few of them by name.'
);

echo Card::for($module, I18N::translate('Occupation inheritance from father to son'))
    ->withSub(I18N::translate('Which trade a son took up relative to his father'))
    ->withEyebrow(I18N::translate('Heritage'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Craft)
    ->withInfo($occupationInheritanceExplanation, I18N::translate('About this chart'), I18N::translate('About this chart'))
    ->withSpan(12)
    ->withBodyHtml(
        Widget::sankeyFlow($module, 'occupation-inheritance')
            ->withData($occupationInheritance)
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('How the tree grew'))
    ->withKicker(I18N::translate('Population'))
    ->withSub(I18N::translate('Cumulative number of recorded individuals across the documented birth window'))
    ->render();

echo Card::for($module, I18N::translate('Tree growth over time'))
    ->withSub($cumulativeBirthsCardSub)
    ->withEyebrow(I18N::translate('Growth'))
    ->withAccent(Accent::Sage)
    ->withIllustration(Illustration::Tree)
    ->withSpan(12)
    ->withoutFooter()
    ->withBodyHtml(
        Widget::lineChart($module, 'cumulative-births-line')
            ->withData($cumulativeBirthsPayload)
            ->withHeight(260)
            ->with('showArea', true)
            ->render()
    )
    ->render();
?>
</div>

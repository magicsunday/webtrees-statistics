use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\CenturyBarRowMapper;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\HistogramBucketAggregator;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\LabelSorter;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\MediaTypeLabeller;
use MagicSunday\Webtrees\Statistic\View\Accent;
use MagicSunday\Webtrees\Statistic\View\Card;
use MagicSunday\Webtrees\Statistic\View\Component;
use MagicSunday\Webtrees\Statistic\View\EmptyStatePlaceholder;
use MagicSunday\Webtrees\Statistic\View\Illustration;
use MagicSunday\Webtrees\Statistic\View\Section;
use MagicSunday\Webtrees\Statistic\View\Widget;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$sourceCoverage          = $statistic->getSourceCitationCoverage();
$sourceCoverageByCentury = $statistic->getSourceCitationCoverageByCentury();
$gaps                    = $statistic->getMissingEventGaps();
$generation              = $statistic->getAverageGenerationLength();

$ancestorDistribution = $statistic->getAncestorCountDistribution();
$avgPedigree          = $statistic->getAveragePedigreeCompleteness();
$generationDepth      = $statistic->getGenerationDepthSummary();
$endogamy             = $statistic->getEndogamySummary();
$topAncestors         = $statistic->getTopAncestorsByDescendantCount(10);
$totalIndividuals     = $statistic->getTotalIndividuals();
$islands              = $statistic->getConnectedComponents(10);
$totalAncestorsRows   = array_sum($ancestorDistribution);

$recordInventory = $statistic->getRecordInventory();

// Resolve the raw source-media-type tokens to translated labels (unknown and
// blank tokens fold into "Other"), then order the list by label with the
// catch-all "Other" bucket pinned to the end.
$mediaByType = LabelSorter::byLabel(
    MediaTypeLabeller::label($statistic->getMediaByType()),
    I18N::translate('Other'),
);
$mediaFilesTotal = array_sum($mediaByType);

// Core vs. enrichment record groups for the data-set inventory. Labels are
// resolved here so xgettext sees the literals; each group scales its bars
// against its own largest value. Each group's rows are ordered by label rather
// than by count so the list reads by name.
$recordInventoryGroups = [
    [
        'label' => I18N::translate('Core'),
        'data'  => LabelSorter::byLabel([
            I18N::translate('Individuals') => $recordInventory->individuals,
            I18N::translate('Families')    => $recordInventory->families,
        ]),
    ],
    [
        'label' => I18N::translate('Enrichment'),
        'data'  => LabelSorter::byLabel([
            I18N::translate('Sources')       => $recordInventory->sources,
            I18N::translate('Media objects') => $recordInventory->media,
            I18N::translate('Shared notes')  => $recordInventory->sharedNotes,
            I18N::translate('Repositories')  => $recordInventory->repositories,
            I18N::translate('Shared places') => $recordInventory->locations,
        ]),
    ],
];

// BarChart rows for generation-depth distribution + known-ancestors
// distribution. Both render as histograms in design2 — switch from
// ProgressList to BarChart to match. tooltipLabel + tooltipBody are
// pre-built with literal I18N::plural calls so xgettext picks the
// strings up.
//
// Trees with very deep descent chains (royal / mythical-genealogy
// trees) produce 50+ depth buckets. Collapse adjacent depths into
// power-of-five bands ("0–4", "5–9", …) when the raw bucket count
// would not fit the card width without overlapping x-axis ticks.
// `compressByFives` is a no-op for trees that already fit the cap.
$generationDepthDistribution = HistogramBucketAggregator::compressByFives(
    $generationDepth->distribution,
    HistogramBucketAggregator::DEFAULT_MAX_BARS,
);
$generationDepthBars = [];

foreach ($generationDepthDistribution as $bandLabel => $count) {
    // PHP auto-casts numeric-string array keys to int — `$bandLabel`
    // comes back as int when the helper returned plain depth labels
    // ("0", "1", …) and as string for the compressed bands ("0–4").
    $bandLabel             = (string) $bandLabel;
    $bucketCount           = (int) $count;
    $generationDepthBars[] = [
        'label'        => $bandLabel,
        'value'        => $bucketCount,
        'tooltipLabel' => str_contains($bandLabel, '–')
            ? I18N::translate('%s generations', $bandLabel)
            : I18N::plural('%s generation deep', '%s generations deep', (int) $bandLabel, I18N::number((int) $bandLabel)),
        'tooltip' => I18N::plural('%s individual', '%s individuals', $bucketCount, I18N::number($bucketCount)),
    ];
}

$ancestorDistributionBars = [];

foreach ($ancestorDistribution as $bucket => $count) {
    $bucketCount                = (int) $count;
    $ancestorDistributionBars[] = [
        'label'        => (string) $bucket,
        'value'        => $bucketCount,
        'tooltipLabel' => I18N::translate('%s known ancestors', (string) $bucket),
        'tooltip'      => I18N::plural('%s individual', '%s individuals', $bucketCount, I18N::number($bucketCount)),
    ];
}

$gapLabels = [
    'BIRT.event' => I18N::translate('Missing birth event'),
    'BIRT.place' => I18N::translate('Missing birth place'),
    'DEAT.event' => I18N::translate('Missing death event'),
    'DEAT.place' => I18N::translate('Missing death place'),
    'MARR.event' => I18N::translate('Missing marriage event'),
    'MARR.place' => I18N::translate('Missing marriage place'),
];

$gapRows = [];

foreach ($gaps as $gap) {
    $key       = $gap['event'] . '.' . $gap['kind'];
    $gapRows[] = [
        'label' => $gapLabels[$key] ?? ($gap['event'] . ' / ' . $gap['kind']),
        'value' => $gap['value'],
        'total' => $gap['total'],
    ];
}

$sourcedPct      = ($sourceCoverage->total > 0) ? ($sourceCoverage->value / $sourceCoverage->total) * 100 : 0.0;
$completenessPct = $avgPedigree * 100;

$pedigreeExplanation = I18N::translate(
    'The pedigree-completeness index (Lacy 1989) measures how fully an individual\'s ancestry is documented across the first four generations (parents, grandparents, great-grandparents, great-great-grandparents). Each generation counts for one quarter of the score, weighted by the share of that generation\'s slots that are filled — so knowing both parents already yields 0.25, regardless of how many more distant ancestors are missing. The number shown here is the average across every individual in the tree.'
);

$generationDepthExplanation = I18N::translate(
    'The maximum generation depth is the longest unbroken parent-child chain recorded in the tree. The widget walks every individual upward, follows fathers and mothers in parallel, and reports the deepest verified line.'
);

$generationDepthDistributionExplanation = I18N::translate(
    'For every individual, this bucket counts how many generations of descendants are recorded below them in the tree. Bucket 0 = leaf (no descendants), bucket N = an individual whose deepest verified descendant is N generations younger.'
);

$endogamyExplanation = I18N::translate(
    "For every couple where both spouses have at least one parent recorded, the widget walks each spouse's ancestor tree up to four generations and intersects the two sets. A non-empty intersection means the couple share at least one common ancestor. That is the classic signature of cousin marriage and pedigree collapse."
);

$aboutThisChart = I18N::translate('About this chart');

$sourceCoverageByCenturyBars = CenturyBarRowMapper::sourceCoverage($sourceCoverageByCentury);

if ($generation === null) {
    $generationCardBody = EmptyStatePlaceholder::render();
} else {
    // One decimal place so the user reads the actual measurement
    // instead of a rounded integer — "31,8" instead of "32" makes
    // it clear when a tree sits just below the typical band.
    $generationRound    = round($generation, 1);
    $generationCardBody = Component::scalar($module)
        ->with('value', I18N::number($generationRound, 1))
        ->with('unit', I18N::translate('years'))
        ->with('caption', I18N::translate('Averaged across every parent-child pair with parseable birth dates.'))
        ->with('scale', [
            'label'   => I18N::translate('Typical range'),
            'min'     => 20.0,
            'max'     => 40.0,
            'current' => $generationRound,
            'ticks'   => ['20', '25', '30', '35', I18N::translate('40 yr')],
        ])
        ->render();
}

$recordInventoryExplanation = I18N::translate(
    'Core records are the individuals and families that make up the tree itself. Enrichment records — sources, media objects, shared notes, repositories and shared locations — document and substantiate them. The density figure is the number of enrichment records per 100 individuals: a tree built only from names and dates sits near zero, a thoroughly sourced one well above it.'
);

$islandsExplanation = I18N::translate(
    'Each tile is one connected sub-tree: a group of individuals tied together by parentage or marriage, with no link to any other sub-tree. The tile area is proportional to the number of members, the largest first. The label is the most common surname within that sub-tree — so the same surname can mark several separate sub-trees when a family line is not yet connected to the rest of the tree. The final tile sums up every sub-tree beyond the ten largest.'
);

// Partnership-reach: the longest unbroken partnership chain and the single largest
// connected partnership group. The summary is null for a tree with no partnered
// couple chain reaching three people, in which case each card below still
// renders but shows the empty-state placeholder instead of a value or widget
// (mirroring the Endogamy card). The VO → widget-payload mapping only runs
// when a report is present.
$partnershipReach = $statistic->getPartnershipReachSummary();

// The "About this chart" popover text is shared by two of the cards and is
// rendered whether or not a report is present.
$partnershipReachExplanation = I18N::translate(
    'Two people are linked when they were partners — married or not. Following those links from one partner to the next traces a partnership chain; the longest unbroken chain in the tree is shown on the left. The largest connected group on the right is every person reachable from one another through such partnerships, drawn as a web with the person who had the most partners at its centre and the longest chain highlighted.'
);

if ($partnershipReach !== null) {
    $partnershipReachReport = $partnershipReach->jsonSerialize();
    $partnershipGroup       = $partnershipReachReport['group'];

    // Map a genealogy sex code (`F`/`M`/`U`) to the translated word for the
    // tooltip text. This domain label belongs in the consumer, not the neutral
    // chart-lib widget — the literals are call-site so xgettext picks them up.
    $partnershipSexLabel = static fn (string $sex): string => match ($sex) {
        'F'     => I18N::translate('female'),
        'M'     => I18N::translate('male'),
        default => I18N::translate('unknown'),
    };

    // Build the "*birth–death" life span gracefully when either bound is
    // missing (a living / privacy-withheld person carries an empty year). The
    // years print verbatim — a year must never gain a thousands separator.
    $partnershipLifeSpan = static function (string $birth, string $death): string {
        if (($birth === '') && ($death === '')) {
            return '';
        }

        return '*' . $birth . '–' . $death;
    };

    // Compose the rich tooltip body the chart-lib widgets render verbatim:
    // "Name · sex · *birth–death", with the hub's partnership degree appended.
    $partnershipTooltip = static function (array $person, string $sexLabel, string $lifeSpan): string {
        $parts = [$person['label'], $sexLabel];

        if ($lifeSpan !== '') {
            $parts[] = $lifeSpan;
        }

        return implode(' · ', $parts);
    };

    // V1 — the longest chain as a left-to-right bead strip. Each person becomes
    // a bead carrying its display label, a "*birth–death" sub-caption, its sex
    // as the `data-group` the consumer stylesheet colours and a rich `title`
    // the widget renders as a styled tooltip.
    $partnershipChainItems = [];

    foreach ($partnershipReachReport['chain'] as $person) {
        $sexLabel = $partnershipSexLabel($person['sex']);
        $lifeSpan = $partnershipLifeSpan($person['birth'], $person['death']);

        $partnershipChainItems[] = [
            'id'       => $person['xref'],
            'label'    => $person['label'],
            'sublabel' => $lifeSpan,
            'title'    => $partnershipTooltip($person, $sexLabel, $lifeSpan),
            'group'    => $person['sex'],
            'href'     => $person['url'],
        ];
    }

    // Foot legend beneath the chain, mirroring the prototype: the chain length
    // and its partnership count on the left, a sex-shape key on the right. The
    // partnership count is one fewer than the people (N spouses → N-1 unions),
    // never the larger whole-group edge count. The key explains the disc shapes
    // now that sex is encoded by shape (circle = female, rounded square = male),
    // not colour. The consumer owns this wrapper (a `wt-stat-*` class, not
    // `msc-*`), like the network legend; it is appended to the widget body below.
    $partnershipChainCount = count($partnershipReachReport['chain']);

    $partnershipChainFoot = '<div class="wt-stat-sequence-chain-foot">'
        . '<span class="wt-stat-sequence-chain-count">'
        . e(I18N::translate('%s people', I18N::number($partnershipChainCount)))
        . ' · '
        . e(I18N::translate('%s partnerships', I18N::number($partnershipChainCount - 1)))
        . '</span>'
        . '<span class="wt-stat-sequence-chain-legend">'
        . '<span class="wt-stat-sequence-chain-legend-item">'
        . '<i class="wt-stat-sequence-chain-key" data-sex="F" aria-hidden="true"></i>'
        . e($partnershipSexLabel('F'))
        . '</span>'
        . '<span class="wt-stat-sequence-chain-legend-item">'
        . '<i class="wt-stat-sequence-chain-key" data-sex="M" aria-hidden="true"></i>'
        . e($partnershipSexLabel('M'))
        . '</span>'
        . '</span>'
        . '</div>';

    // V2 — the largest group as a force-directed graph. Each node carries a
    // rich `title` tooltip, the hub is emphasised, and every edge lying on the
    // longest-chain path is highlighted. `chainIds` doubles as the highlight
    // path so the graph draws the chain through the cluster. Node colour comes
    // from chain membership (highlighted / hub / off-chain) via CSS, NOT sex.
    $partnershipGroupChainPairs = [];

    for ($i = 1, $count = count($partnershipGroup['chainIds']); $i < $count; ++$i) {
        $a = $partnershipGroup['chainIds'][$i - 1];
        $b = $partnershipGroup['chainIds'][$i];

        $partnershipGroupChainPairs[$a . "\0" . $b] = true;
        $partnershipGroupChainPairs[$b . "\0" . $a] = true;
    }

    $partnershipGroupNodes = [];

    foreach ($partnershipGroup['nodes'] as $node) {
        $sexLabel = $partnershipSexLabel($node['sex']);
        $lifeSpan = $partnershipLifeSpan($node['birth'], $node['death']);
        $title    = $partnershipTooltip($node, $sexLabel, $lifeSpan);

        if ($node['xref'] === $partnershipGroup['hubId']) {
            $title .= ' · ' . I18N::translate('%s partnerships', I18N::number($partnershipGroup['hubDegree']));
        }

        $partnershipGroupNodes[] = [
            'id'       => $node['xref'],
            'label'    => $node['label'],
            'title'    => $title,
            'emphasis' => $node['xref'] === $partnershipGroup['hubId'],
            'href'     => $node['url'],
        ];
    }

    $partnershipGroupLinks = [];

    foreach ($partnershipGroup['edges'] as $edge) {
        $partnershipGroupLinks[] = [
            'source'      => $edge[0],
            'target'      => $edge[1],
            'highlighted' => isset($partnershipGroupChainPairs[$edge[0] . "\0" . $edge[1]]),
        ];
    }

    $partnershipGroupPayload = [
        'nodes'         => $partnershipGroupNodes,
        'links'         => $partnershipGroupLinks,
        'highlightPath' => $partnershipGroup['chainIds'],
        'hubId'         => $partnershipGroup['hubId'],
        'totalCount'    => $partnershipGroup['totalCount'],
        'shownCount'    => $partnershipGroup['shownCount'],
    ];

    // K2 — caption naming the group's median life year, when any member is
    // dated. A year prints verbatim — `I18N::number` would add the German
    // thousands separator ("1.934"), so cast the year to a plain string.
    $partnershipGroupCaption = ($partnershipGroup['medianYear'] !== null)
        ? I18N::translate('People joined by partnership · median life around %s', (string) $partnershipGroup['medianYear'])
        : I18N::translate('People joined by partnership');

    // Foot legend strip beneath the network: the longest chain length, the
    // group size and edge count, and the median life year — mirroring the
    // prototype. Both counts describe the WHOLE group (`totalCount` people,
    // `totalEdgeCount` partnerships), never the capped excerpt that is drawn, so
    // the legend never pairs a full-group people count with an excerpt-only
    // partnership count. Years print verbatim (no thousands separator); the counts
    // go through `I18N::number`. The legend is appended to the widget body below.
    $partnershipNetworkLegendParts = [
        I18N::translate('Longest chain (%s)', I18N::number(count($partnershipGroup['chainIds']))),
        I18N::translate('%s people', I18N::number($partnershipGroup['totalCount'])),
        I18N::translate('%s partnerships', I18N::number($partnershipGroup['totalEdgeCount'])),
    ];

    if ($partnershipGroup['medianYear'] !== null) {
        $partnershipNetworkLegendParts[] = I18N::translate('Median %s', (string) $partnershipGroup['medianYear']);
    }

    $partnershipNetworkLegend = '<p class="wt-stat-network-graph-legend">'
        . e(implode(' · ', $partnershipNetworkLegendParts))
        . '</p>';
}
?>
<div class="wt-stat-grid">
<?php
echo Section::create(I18N::translate('What is the tree made of?'))
    ->withKicker(I18N::translate('Data-set inventory'))
    ->withSub(I18N::translate('Core records (individuals and families) against the enrichment records that document them'))
    ->render();

echo Card::for($module, I18N::translate('Data-set inventory'))

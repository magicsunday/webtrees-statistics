echo Card::for($module, I18N::translate('Top 10 most-influential ancestors'))
    ->withSub(I18N::translate('Individuals with the most documented descendants · the structural roots of the tree'))
    ->withEyebrow(I18N::translate('Reach'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Tree)
    ->withInfo(
        I18N::translate(
            'For every individual in the tree the widget counts how many descendants are recorded below them across all generations. A descendant reached through two different grandparents is counted once per ancestor. The ranking surfaces the people whose branches actually carry the rest of the recorded lineage.'
        ),
        $aboutThisChart,
        $aboutThisChart
    )
    ->withSpan(12)
    ->withBodyHtml(
        Component::podium($module)
            ->with('class', 'progress-top-ancestors')
            ->withData($topAncestors)
            ->with('suffix', I18N::translate('desc.'))
            ->render()
    )
    ->render();

// The partnership-reach cards form their own section: three summary KPIs (chain
// length, group size and the depth-to-breadth ratio) followed by the two detail
// visualisations (the chain strip and the group network).
echo Section::create(I18N::translate('How far does the tree connect through partnerships?'))
    ->withKicker(I18N::translate('Partnership reach'))
    ->withSub(I18N::translate('Chains and clusters formed by partnership'))
    ->render();

// The partnership-reach cards always render. When no partnered couple forms a chain
// of three or more people (`$partnershipReach === null`), each card keeps its
// heading and shows the empty-state placeholder as its body — mirroring the
// Endogamy card — instead of the whole block vanishing.
echo Card::for($module, I18N::translate('Longest partnership chain'))
    ->withSub(I18N::translate('Unbroken partner-to-partner line'))
    ->withEyebrow(I18N::translate('Reach'))
    ->withAccent(Accent::Rose)
    ->withIllustration(Illustration::Rings)
    ->withInfo($partnershipReachExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml(
        ($partnershipReach === null)
            ? EmptyStatePlaceholder::render()
            : Component::scalar($module)
                ->with('value', I18N::number($partnershipReach->longestChainLength))
                ->with('unit', I18N::translate('people'))
                ->with('caption', I18N::translate('Each step is one partnership further along the line.'))
                ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Largest connected group'))
    ->withSub(I18N::translate('Biggest web of partnered people'))
    ->withEyebrow(I18N::translate('Reach'))
    ->withAccent(Accent::Rose)
    ->withIllustration(Illustration::Knot)
    ->withSpan(4)
    ->withFooter()
    ->centered()
    ->withBodyHtml(
        ($partnershipReach === null)
            ? EmptyStatePlaceholder::render()
            : Component::scalar($module)
                ->with('value', I18N::number($partnershipReach->group->totalCount))
                ->with('unit', I18N::translate('people'))
                ->with('caption', $partnershipGroupCaption)
                ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Depth-to-breadth ratio'))
    ->withSub(I18N::translate('Deepest line against the longest partnership chain'))
    ->withEyebrow(I18N::translate('Reach'))
    ->withAccent(Accent::Rose)
    ->withIllustration(Illustration::Bell)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml(
        ($partnershipReach === null)
            ? EmptyStatePlaceholder::render()
            : Component::scalar($module)
                ->with('value', I18N::number($partnershipReach->depthPath) . ' : ' . I18N::number($partnershipReach->breadthChain))
                ->with('caption', I18N::translate('Generations deep versus people wide. A tall tree runs deep, a broad one spreads sideways.'))
                ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('The longest chain, person by person'))
    ->withSub(I18N::translate('Every partner on the longest line, in order'))
    ->withEyebrow(I18N::translate('Reach'))
    ->withAccent(Accent::Rose)
    ->withIllustration(Illustration::Rings)
    ->withSpan(12)
    ->withBodyHtml(
        ($partnershipReach === null)
            ? EmptyStatePlaceholder::render()
            : Widget::sequenceChain($module, 'partnership-chain-sequence')
                ->withData(['items' => $partnershipChainItems])
                ->withAriaLabel(I18N::translate('Longest partnership chain'))
                ->render()
            . $partnershipChainFoot
    )
    ->render();

echo Card::for($module, I18N::translate('Largest connected partnership group'))
    ->withSub(I18N::translate('Partnership web · the longest chain highlighted'))
    ->withEyebrow(I18N::translate('Reach'))
    ->withAccent(Accent::Rose)
    ->withIllustration(Illustration::Knot)
    ->withInfo($partnershipReachExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(12)
    ->withBodyHtml(
        ($partnershipReach === null)
            ? EmptyStatePlaceholder::render()
            : Widget::networkGraph($module, 'partnership-group-network')
                ->withData($partnershipGroupPayload)
                ->withHeight(360)
                ->withAccent(Accent::Rose)
                ->with('capBadge', I18N::translate('%1$s of %2$s shown', '{shown}', '{total}'))
                ->withAriaLabel(I18N::translate('Largest connected partnership group'))
                ->render()
            . $partnershipNetworkLegend
    )
    ->render();

echo Section::create(I18N::translate('Connected and unconnected sub-trees'))
    ->withKicker(I18N::translate('Structure type'))
    ->withSub(I18N::translate('How many connected sub-trees are there? A family tree has one large sub-tree, an address book many small ones.'))
    ->render();

echo Card::for($module, I18N::translate('Largest unconnected sub-trees'))
    ->withSub(I18N::translate('%1$s sub-trees total · the largest covers %2$s%% of all individuals', I18N::number($islands->totalIslands), I18N::number($islands->largestPercent())))
    ->withEyebrow(I18N::translate('Structure'))

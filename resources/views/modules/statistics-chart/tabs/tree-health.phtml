    ->render();

echo Card::for($module, I18N::translate('Tree type'))
    ->withSub(I18N::translate('Share of the largest sub-tree'))
    ->withEyebrow(I18N::translate('Diagnosis'))
    ->withAccent(Accent::Sage)
    ->withIllustration(Illustration::Tree)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml(

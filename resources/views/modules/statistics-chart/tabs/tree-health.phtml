declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\CenturyBarRowMapper;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\HistogramBucketAggregator;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\MediaTypeLabeller;
use MagicSunday\Webtrees\Statistic\View\Accent;
use MagicSunday\Webtrees\Statistic\View\Card;
use MagicSunday\Webtrees\Statistic\View\Component;
use MagicSunday\Webtrees\Statistic\View\EmptyStatePlaceholder;
use MagicSunday\Webtrees\Statistic\View\Illustration;
use MagicSunday\Webtrees\Statistic\View\Section;
use MagicSunday\Webtrees\Statistic\View\Widget;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$sourceCoverage          = $statistic->getSourceCitationCoverage();
$sourceCoverageByCentury = $statistic->getSourceCitationCoverageByCentury();
$gaps                    = $statistic->getMissingEventGaps();
$generation              = $statistic->getAverageGenerationLength();

$ancestorDistribution = $statistic->getAncestorCountDistribution();
$avgPedigree          = $statistic->getAveragePedigreeCompleteness();
$generationDepth      = $statistic->getGenerationDepthSummary();
$endogamy             = $statistic->getEndogamySummary();
$topAncestors         = $statistic->getTopAncestorsByDescendantCount(10);
$totalIndividuals     = $statistic->getTotalIndividuals();
$islands              = $statistic->getConnectedComponents(10);
$totalAncestorsRows   = array_sum($ancestorDistribution);

$recordInventory = $statistic->getRecordInventory();

// Resolve the raw source-media-type tokens to translated labels (unknown and
// blank tokens fold into "Other"); the repository already orders by frequency.
$mediaByType     = MediaTypeLabeller::label($statistic->getMediaByType());
$mediaFilesTotal = array_sum($mediaByType);

// Core vs. enrichment record groups for the data-set inventory. Labels are
// resolved here so xgettext sees the literals; each group scales its bars
// against its own largest value.
$recordInventoryGroups = [
    [
        'label' => I18N::translate('Core'),
        'data'  => [
            I18N::translate('Individuals') => $recordInventory->individuals,
            I18N::translate('Families')    => $recordInventory->families,
        ],
    ],
    [
        'label' => I18N::translate('Enrichment'),
        'data'  => [
            I18N::translate('Sources')       => $recordInventory->sources,
            I18N::translate('Media objects') => $recordInventory->media,
            I18N::translate('Notes')         => $recordInventory->notes,
            I18N::translate('Shared notes')  => $recordInventory->sharedNotes,
            I18N::translate('Repositories')  => $recordInventory->repositories,
            I18N::translate('Shared places') => $recordInventory->locations,
        ],
    ],
];

// BarChart rows for generation-depth distribution + known-ancestors
// distribution. Both render as histograms in design2 — switch from
// ProgressList to BarChart to match. tooltipLabel + tooltipBody are
// pre-built with literal I18N::plural calls so xgettext picks the
// strings up.
//
// Trees with very deep descent chains (royal / mythical-genealogy
// trees) produce 50+ depth buckets. Collapse adjacent depths into
// power-of-five bands ("0–4", "5–9", …) when the raw bucket count
// would not fit the card width without overlapping x-axis ticks.
// `compressByFives` is a no-op for trees that already fit the cap.
$generationDepthDistribution = HistogramBucketAggregator::compressByFives(
    $generationDepth->distribution,
    HistogramBucketAggregator::DEFAULT_MAX_BARS,
);
$generationDepthBars = [];

foreach ($generationDepthDistribution as $bandLabel => $count) {
    // PHP auto-casts numeric-string array keys to int — `$bandLabel`
    // comes back as int when the helper returned plain depth labels
    // ("0", "1", …) and as string for the compressed bands ("0–4").
    $bandLabel             = (string) $bandLabel;
    $bucketCount           = (int) $count;
    $generationDepthBars[] = [
        'label'        => $bandLabel,
        'value'        => $bucketCount,
        'tooltipLabel' => str_contains($bandLabel, '–')
            ? I18N::translate('%s generations', $bandLabel)
            : I18N::plural('%s generation deep', '%s generations deep', (int) $bandLabel, I18N::number((int) $bandLabel)),
        'tooltip' => I18N::plural('%s individual', '%s individuals', $bucketCount, I18N::number($bucketCount)),
    ];
}

$ancestorDistributionBars = [];

foreach ($ancestorDistribution as $bucket => $count) {
    $bucketCount                = (int) $count;
    $ancestorDistributionBars[] = [
        'label'        => (string) $bucket,
        'value'        => $bucketCount,
        'tooltipLabel' => I18N::translate('%s known ancestors', (string) $bucket),
        'tooltip'      => I18N::plural('%s individual', '%s individuals', $bucketCount, I18N::number($bucketCount)),
    ];
}

$gapLabels = [
    'BIRT.event' => I18N::translate('Missing birth event'),
    'BIRT.place' => I18N::translate('Missing birth place'),
    'DEAT.event' => I18N::translate('Missing death event'),
    'DEAT.place' => I18N::translate('Missing death place'),
    'MARR.event' => I18N::translate('Missing marriage event'),
    'MARR.place' => I18N::translate('Missing marriage place'),
];

$gapRows = [];

foreach ($gaps as $gap) {
    $key       = $gap['event'] . '.' . $gap['kind'];
    $gapRows[] = [
        'label' => $gapLabels[$key] ?? ($gap['event'] . ' / ' . $gap['kind']),
        'value' => $gap['value'],
        'total' => $gap['total'],
    ];
}

$sourcedPct      = ($sourceCoverage->total > 0) ? ($sourceCoverage->value / $sourceCoverage->total) * 100 : 0.0;
$completenessPct = $avgPedigree * 100;

$pedigreeExplanation = I18N::translate(
    'Each person in the tree has up to 30 possible direct ancestors within four generations (2 parents + 4 grandparents + 8 great-grandparents + 16 great-great-grandparents). The pedigree-completeness index (Lacy 1989) is the fraction of those 30 slots that are actually documented for that individual. The number shown here is the average across every individual in the tree.'
);

$generationDepthExplanation = I18N::translate(
    'The maximum generation depth is the longest unbroken parent-child chain recorded in the tree. The widget walks every individual upward, follows fathers and mothers in parallel, and reports the deepest verified line.'
);

$generationDepthDistributionExplanation = I18N::translate(
    'For every individual, this bucket counts how many generations of descendants are recorded below them in the tree. Bucket 0 = leaf (no descendants), bucket N = an individual whose deepest verified descendant is N generations younger.'
);

$endogamyExplanation = I18N::translate(
    "For every couple where both spouses have at least one parent recorded, the widget walks each spouse's ancestor tree up to four generations and intersects the two sets. A non-empty intersection means the couple share at least one common ancestor. That is the classic signature of cousin marriage and pedigree collapse."
);

$aboutThisChart = I18N::translate('About this chart');

$sourceCoverageByCenturyBars = CenturyBarRowMapper::sourceCoverage($sourceCoverageByCentury);

if ($generation === null) {
    $generationCardBody = EmptyStatePlaceholder::render();
} else {
    // One decimal place so the user reads the actual measurement
    // instead of a rounded integer — "31,8" instead of "32" makes
    // it clear when a tree sits just below the typical band.
    $generationRound    = round($generation, 1);
    $generationCardBody = Component::scalar($module)
        ->with('value', I18N::number($generationRound, 1))
        ->with('unit', I18N::translate('years'))
        ->with('caption', I18N::translate('Averaged across every parent-child pair with parseable birth dates.'))
        ->with('scale', [
            'label'   => I18N::translate('Typical range'),
            'min'     => 20.0,
            'max'     => 40.0,
            'current' => $generationRound,
            'ticks'   => ['20', '25', '30', '35', I18N::translate('40 yr')],
        ])
        ->render();
}
?>
<div class="wt-stat-grid">
<?php
echo Section::create(I18N::translate('How well is the tree documented?'))
    ->withKicker(I18N::translate('Documentation'))
    ->withSub(I18N::translate('Source coverage, completeness and average generation length'))
    ->render();

echo Card::for($module, I18N::translate('Source-citation coverage'))
    ->withSub(I18N::translate('Individuals with at least one source'))
    ->withEyebrow(I18N::translate('Documentation'))
    ->withAccent(Accent::Sage)
    ->withIllustration(Illustration::Book)
    ->withSpan(4)
    ->centered()
    ->withFooter()
    ->withBodyHtml(
        Widget::gaugeArc($module)
            ->with('value', $sourcedPct)
            ->withAccent(Accent::Sage)
            ->with('label', I18N::translate('documented'))
            ->with('meta', I18N::translate('%1$s of %2$s', I18N::number($sourceCoverage->value), I18N::number($sourceCoverage->total)))
            ->with('caption', I18N::translate('Individuals with ≥ 1 source citation'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Pedigree completeness'))
    ->withSub(I18N::translate('Lacy index · average share of known ancestors up to the 4th generation'))
    ->withEyebrow(I18N::translate('Completeness'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Magnifier)
    ->withInfo($pedigreeExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml(
        Widget::gaugeArc($module)
            ->with('value', $completenessPct)
            ->withAccent(Accent::Wine)
            ->with('label', I18N::translate('Lacy 1989'))
            ->with('meta', I18N::plural('%s individual sampled', '%s individuals sampled', $totalAncestorsRows, I18N::number($totalAncestorsRows)))
            ->with('caption', I18N::translate('Higher = more thorough research'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Generation length'))
    ->withSub(I18N::translate('Average birth-year gap parent → child'))
    ->withEyebrow(I18N::translate('Time'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Hourglass)
    ->withSpan(4)
    ->centered()
    ->withFooter()
    ->withBodyHtml($generationCardBody)
    ->render();

echo Card::for($module, I18N::translate('Source coverage by century'))
    ->withSub(I18N::translate('Share of individuals with at least one source citation, per birth century'))
    ->withEyebrow(I18N::translate('Documentation'))
    ->withAccent(Accent::Sage)
    ->withIllustration(Illustration::Book)
    ->withSpan(6)
    ->withBodyHtml(
        Widget::barChart($module, 'source-coverage-by-century-bars')
            ->withData($sourceCoverageByCenturyBars)
            ->withHeight(220)
            ->withAriaLabel(I18N::translate('Source coverage by century'))
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('What is missing?'))
    ->withKicker(I18N::translate('Gaps'))
    ->withSub(I18N::translate('Where the tree has gaps · events and places not recorded'))
    ->render();

echo Card::for($module, I18N::translate('Missing-event gaps'))
    ->withSub(I18N::translate('Share of individuals without a recorded birth, death or marriage event'))
    ->withEyebrow(I18N::translate('Gaps'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Magnifier)
    ->withSpan(12)
    ->withBodyHtml(
        Component::heatStrip($module)
            ->with('rows', $gapRows)
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('How deep and branched is the tree?'))
    ->withKicker(I18N::translate('Structure'))
    ->withSub(I18N::translate('Generation depth, ancestor distribution and kin marriages'))
    ->render();

echo Card::for($module, I18N::translate('Maximum generation depth'))
    ->withSub(I18N::translate('Longest line in the tree, leaf to oldest ancestor'))
    ->withEyebrow(I18N::translate('Depth'))
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::Tree)
    ->withInfo($generationDepthExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml(
        Component::scalar($module)
            ->with('value', I18N::number($generationDepth->maxDepth))
            ->with('unit', I18N::translate('generations'))
            ->with(
                'caption',
                $generationDepth->capped
                    ? I18N::translate('Walk reached the safety cap (100 generations) — check the tree for cyclic FAMC/FAMS edits.')
                    : I18N::translate('Each step is one parent–child link upward.')
            )
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Generation depth distribution'))
    ->withSub(I18N::translate('Individuals N generations above their deepest descendant'))
    ->withEyebrow(I18N::translate('Structure'))
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::Tree)
    ->withInfo($generationDepthDistributionExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(8)
    ->withBodyHtml(
        Widget::barChart($module, 'generation-depth-bars')
            ->withData($generationDepthBars)
            ->with('xLabel', I18N::translate('Generations'))
            ->withAriaLabel(I18N::translate('Generation depth distribution'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Known ancestors per individual'))
    ->withSub(I18N::translate('Distinct ancestors up to 4 generations (max. 30)'))
    ->withEyebrow(I18N::translate('Ancestors'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Family)
    ->withSpan(8)
    ->withBodyHtml(
        Widget::barChart($module, 'ancestor-count-bars')
            ->withData($ancestorDistributionBars)
            ->with('xLabel', I18N::translate('Ancestors'))
            ->withAriaLabel(I18N::translate('Known ancestors per individual'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Top 10 most-influential ancestors'))
    ->withSub(I18N::translate('Individuals with the most documented descendants · the structural roots of the tree'))
    ->withEyebrow(I18N::translate('Reach'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Tree)
    ->withInfo(
        I18N::translate(
            'For every individual in the tree the widget counts how many descendants are recorded below them across all generations. A descendant reached through two different grandparents is counted once per ancestor. The ranking surfaces the people whose branches actually carry the rest of the recorded lineage.'
        ),
        $aboutThisChart,
        $aboutThisChart
    )
    ->withSpan(6)
    ->withBodyHtml(
        Component::podium($module)
            ->with('class', 'progress-top-ancestors')
            ->withData($topAncestors)
            ->with('suffix', I18N::translate('desc.'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Endogamy rate'))
    ->withSub(I18N::translate('Share of marriages within 4 generations'))
    ->withEyebrow(I18N::translate('Kinship'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Knot)
    ->withInfo($endogamyExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml(
        ($endogamy === null)
            ? EmptyStatePlaceholder::render()
            : Component::scalar($module)
                ->with('value', I18N::number($endogamy->rate, 1))
                ->with('unit', '%')
                ->with(
                    'caption',
                    I18N::plural(
                        '%1$s of %2$s couple where both spouses had at least one recorded parent share a common ancestor.',
                        '%1$s of %2$s couples where both spouses had at least one recorded parent share a common ancestor.',
                        $endogamy->total,
                        I18N::number($endogamy->endogamous),
                        I18N::number($endogamy->total),
                    )
                )
                ->render()
    )
    ->render();

$islandsExplanation = I18N::translate(
    'Each tile is one connected sub-tree: a group of individuals tied together by parentage or marriage, with no link to any other sub-tree. The tile area is proportional to the number of members, the largest first. The label is the most common surname within that sub-tree — so the same surname can mark several separate sub-trees when a family line is not yet connected to the rest of the tree. The final tile sums up every sub-tree beyond the ten largest.'
);

echo Section::create(I18N::translate('Connected and unconnected sub-trees'))
    ->withKicker(I18N::translate('Structure type'))
    ->withSub(I18N::translate('How many connected sub-trees are there? A family tree has one large sub-tree, an address book many small ones.'))
    ->render();

echo Card::for($module, I18N::translate('Largest unconnected sub-trees'))
    ->withSub(I18N::translate('%1$s sub-trees total · the largest covers %2$s%% of all individuals', I18N::number($islands->totalIslands), I18N::number($islands->largestPercent())))
    ->withEyebrow(I18N::translate('Structure'))
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::Tree)
    ->withInfo($islandsExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(8)
    ->withBodyHtml(
        Widget::treemap($module, 'islands-treemap')
            ->withData([
                'items'       => $islands->top,
                'restMembers' => $islands->restMembers,
            ])
            ->withAccent(Accent::Slate)
            ->withHeight(360)
            ->with('valueLabel', I18N::translate('persons'))
            ->with('restLabel', I18N::translate('other sub-trees'))
            ->withAriaLabel(I18N::translate('Largest unconnected sub-trees'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Tree type'))
    ->withSub(I18N::translate('Share of the largest sub-tree'))
    ->withEyebrow(I18N::translate('Diagnosis'))
    ->withAccent(Accent::Sage)
    ->withIllustration(Illustration::Tree)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml(
        Component::scalar($module)
            ->with('value', I18N::number($islands->largestPercent()))
            ->with('unit', '%')
            ->with('caption', I18N::translate('of all individuals lie in a single sub-tree. A high value is a closed family tree; a low value an address-book-like scatter of many fragments.'))
            ->render()
    )
    ->render();

$recordInventoryExplanation = I18N::translate(
    'Core records are the individuals and families that make up the tree itself. Enrichment records — sources, media objects, notes, repositories and shared locations — document and substantiate them. The density figure is the number of enrichment records per 100 individuals: a tree built only from names and dates sits near zero, a thoroughly sourced one well above it.'
);

echo Section::create(I18N::translate('What is the tree made of?'))
    ->withKicker(I18N::translate('Data-set inventory'))
    ->withSub(I18N::translate('Core records (individuals and families) against the enrichment records that document them'))
    ->render();

echo Card::for($module, I18N::translate('Data-set inventory'))
    ->withSub(I18N::translate('%s enrichment records per 100 individuals', I18N::number($recordInventory->enrichmentDensity())))
    ->withEyebrow(I18N::translate('Composition'))
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::Book)
    ->withInfo($recordInventoryExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(6)
    ->withBodyHtml(
        Component::recordInventory($module)
            ->with('groups', $recordInventoryGroups)
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Media objects by type'))
    ->withSub(I18N::plural('%s media file in total', '%s media files in total', $mediaFilesTotal, I18N::number($mediaFilesTotal)))
    ->withEyebrow(I18N::translate('Media'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Book)
    ->withSpan(6)
    ->withBodyHtml(
        Component::progressList($module)
            ->with('class', 'progress-media-types')
            ->withData($mediaByType)
            ->render()
    )
    ->render();
?>
</div>

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;
use MagicSunday\Webtrees\Statistic\View\Accent;
use MagicSunday\Webtrees\Statistic\View\Card;
use MagicSunday\Webtrees\Statistic\View\Illustration;
use MagicSunday\Webtrees\Statistic\View\Section;
use MagicSunday\Webtrees\Statistic\View\Widget;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$totalSurnames         = $statistic->getTotalSurnames();
$totalMaleGivenNames   = $statistic->getTotalMaleGivenNames();
$totalFemaleGivenNames = $statistic->getTotalFemaleGivenNames();
$topSurnames           = $statistic->getTopSurnames(15);
$topMaleGivenNames     = $statistic->getTopMaleGivenNames(15);
$topFemaleGivenNames   = $statistic->getTopFemaleGivenNames(15);
$givenNameTrends       = $statistic->getGivenNameTrends(10);
$surnameMarriageMatrix = $statistic->getSurnameMarriageMatrix(8);
$namePassdown          = $statistic->getSameSexNamePassdownByCentury();

$streamGraphExplanation = I18N::translate(
    "Each band stands for one of the most common given names in the tree. The band's vertical thickness in a given decade shows how many individuals born in that decade carried that name. The silhouette layout centres each band around zero, so the chart reads as relative magnitudes. Hover any band to see absolute counts and its peak decade."
);

$surnameMarriageMatrixExplanation = I18N::translate(
    'Each arc on the circumference is one of the top surnames in the tree, ranked by how many marriages that surname appears in (as husband or wife). Ribbons between two arcs encode the number of marriages between those surnames. The ribbon thickness is proportional to that count. The diagram is symmetric, so a Schmidt × Müller marriage contributes equally to both arcs. Self-loops on an arc represent endogamous marriages where husband and wife share a surname.'
);

$aboutThisChart = I18N::translate('About this chart');
?>
<div class="wt-stat-grid">
<?php
echo Section::create(I18N::translate('Which names return?'))
    ->withKicker(I18N::translate('Frequencies'))
    ->withSub(I18N::translate('Family names and given names by frequency across the tree'))
    ->render();

echo Card::for($module, I18N::translate('Common surnames'))
    ->withSub(I18N::translate('%s distinct surnames (top 15)', I18N::number($totalSurnames)))
    ->withEyebrow(I18N::translate('Surnames'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Tree)
    ->withSpan(12)
    ->withoutFooter()
    ->withBodyHtml(
        Widget::nameBubbles($module)
            ->withData($topSurnames)
            ->withAccent(Accent::Wine)
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Common given names – male'))
    ->withSub(I18N::translate('%s distinct given names (top 15)', I18N::number($totalMaleGivenNames)))
    ->withEyebrow(I18N::translate('Given names'))
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::People)
    ->withSpan(6)
    ->withoutFooter()
    ->withBodyHtml(
        Widget::nameBubbles($module)
            ->withData($topMaleGivenNames)
            ->withAccent(Accent::Slate)
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Common given names – female'))
    ->withSub(I18N::translate('%s distinct given names (top 15)', I18N::number($totalFemaleGivenNames)))
    ->withEyebrow(I18N::translate('Given names'))
    ->withAccent(Accent::Rose)
    ->withIllustration(Illustration::People)
    ->withSpan(6)
    ->withoutFooter()
    ->withBodyHtml(
        Widget::nameBubbles($module)
            ->withData($topFemaleGivenNames)
            ->withAccent(Accent::Rose)
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('How names came and went over time'))
    ->withKicker(I18N::translate('Evolution'))
    ->withSub(I18N::translate('Popularity over decades and marriage alliances between families'))
    ->render();

echo Card::for($module, I18N::translate('Given-name popularity across decades'))
    ->withSub(I18N::translate('Top %s given names, stacked · band thickness = share per decade', I18N::number(count($givenNameTrends->names))))
    ->withEyebrow(I18N::translate('Timeline'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Tree)
    ->withInfo($streamGraphExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(12)
    ->withBodyHtml(
        Widget::streamGraph($module, 'given-name-trends-stream')
            ->withData($givenNameTrends)
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Same-sex name passdown'))
    ->withSub(I18N::translate('Share of children sharing at least one given name with the same-sex parent'))
    ->withEyebrow(I18N::translate('Tradition'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Tree)
    ->withInfo(
        I18N::translate(
            'For every parent-child pair of the same sex (father / son and mother / daughter) where both individuals carry a recorded given name, the widget tokenises each name and counts the pair as a match when at least one token appears on both sides. Order and position do not matter. The chart carries one series per sex pairing on a shared X axis, so the two traditions can be compared at a glance. Centuries with fewer than 10 recorded pairs are suppressed independently per series because a single match would swing the rate by more than 10 percentage points.'
        ),
        $aboutThisChart,
        $aboutThisChart
    )
    ->withSpan(12)
    ->withBodyHtml(
        Widget::lineChart($module, 'same-sex-name-passdown-line')
            ->withData($namePassdown)
            ->with('multiSeriesArea', true)
            ->with('yUnit', ' %')
            ->withAriaLabel(I18N::translate('Same-sex name passdown'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Surname × surname marriage matrix'))
    ->withSub(I18N::translate('Chord diagram: arcs = surnames, ribbons = marriages between them, loops = endogamy'))
    ->withEyebrow(I18N::translate('Alliances'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Knot)
    ->withInfo($surnameMarriageMatrixExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(12)
    ->withBodyHtml(
        Widget::chordDiagram($module, 'surname-marriage-chord')
            ->withData($surnameMarriageMatrix)
            ->withAriaLabel(I18N::translate('Surname × surname marriage matrix'))
            ->render()
    )
    ->render();
?>
</div>

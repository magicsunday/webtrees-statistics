declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Model\LineChart\LineChartPayload;
use MagicSunday\Webtrees\Statistic\Statistic;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\CenturyBarRowMapper;
use MagicSunday\Webtrees\Statistic\Support\Aggregator\DecadeBinCollapser;
use MagicSunday\Webtrees\Statistic\Support\Calc\HistogramTrim;
use MagicSunday\Webtrees\Statistic\Support\Locale\CenturyName;
use MagicSunday\Webtrees\Statistic\Support\Locale\DecadeName;
use MagicSunday\Webtrees\Statistic\View\Accent;
use MagicSunday\Webtrees\Statistic\View\Card;
use MagicSunday\Webtrees\Statistic\View\Component;
use MagicSunday\Webtrees\Statistic\View\EmptyStatePlaceholder;
use MagicSunday\Webtrees\Statistic\View\Illustration;
use MagicSunday\Webtrees\Statistic\View\LegendPosition;
use MagicSunday\Webtrees\Statistic\View\Section;
use MagicSunday\Webtrees\Statistic\View\Widget;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$birthsByMonth      = $statistic->getBirthsByMonth();
$birthsByZodiacSign = $statistic->getBirthsByZodiacSign();
$birthsByCentury    = $statistic->getBirthsByCentury();
$birthsByDecade     = $statistic->getBirthsByDecade();
$deathsByMonth      = $statistic->getDeathsByMonth();
$deathsByCentury    = $statistic->getDeathsByCentury();

$ageAtDeath              = $statistic->getAgeAtDeathDistribution();
$topOldestDeceased       = $statistic->getTopOldestDeceased(10);
$topOldestLiving         = $statistic->getTopOldestLiving(10);
$livingByAgeBand         = $statistic->getLivingByAgeBand();
$topDeathCauses          = $statistic->getTopDeathCauses(15);
$totalDeathCauses        = $statistic->getTotalDeathCauses();
$winterPeakScore         = $statistic->getDeathWinterPeakScore();
$childMortality          = $statistic->getChildMortalitySummary();
$childMortalityByCentury = $statistic->getChildMortalityByBirthCentury();
$lifespanBySexCentury    = $statistic->getAverageLifespanBySexAndCentury();
$survivalByCentury       = $statistic->getSurvivalCurveByCentury();
$ageDistByCentury        = $statistic->getDeathAgeDistributionByCentury();

$totalBirthsByMonth   = array_sum($birthsByMonth);
$totalBirthsByZodiac  = array_sum($birthsByZodiacSign);
$totalBirthsByCentury = array_sum($birthsByCentury);
$totalBirthsByDecade  = array_sum($birthsByDecade);
$totalDeathsByMonth   = array_sum($deathsByMonth);
$totalDeathsByCentury = array_sum($deathsByCentury);
$totalAgeAtDeath      = array_sum($ageAtDeath);
$totalLivingBanded    = array_sum(array_column($livingByAgeBand, 'value'));

// Enrich the living-age-band slices with long-form tooltip text
// (band-in-years header + plural-aware "N persons" body). The donut
// widget falls back to label/value when tooltipLabel/tooltipBody
// are missing, so the enrichment is local to this template.
$livingByAgeBand = array_map(
    static function (array $band): array {
        $value = $band['value'];

        return $band + [
            'tooltipLabel' => I18N::translate('%s years', $band['label']),
            'tooltipBody'  => I18N::plural('%s person', '%s persons', $value, I18N::number($value)),
        ];
    },
    $livingByAgeBand,
);

$birthsByDecadeBinSize = DecadeBinCollapser::pickBinSize(count($birthsByDecade));
$birthsByDecadePlot    = DecadeBinCollapser::collapseCounts($birthsByDecade);

$birthsByDecadeCardTitle = match ($birthsByDecadeBinSize) {
    1       => I18N::translate('Births by decade'),
    5       => I18N::translate('Births per half-century'),
    10      => I18N::translate('Births per century'),
    50      => I18N::translate('Births per half-millennium'),
    100     => I18N::translate('Births per millennium'),
    default => I18N::translate('Births per %s-decade period', I18N::number($birthsByDecadeBinSize)),
};
$birthsByDecadeCardSub = I18N::plural('%s recorded birth date', '%s recorded birth dates', $totalBirthsByDecade, I18N::number($totalBirthsByDecade));

if ($birthsByDecadeBinSize > 1) {
    $birthsByDecadeCardSub .= ' — ' . I18N::translate(
        'aggregated into %s-decade bins for readability',
        I18N::number($birthsByDecadeBinSize),
    );
}

$birthsByDecadePayload = LineChartPayload::singleSeries(
    seriesName: I18N::translate('Births'),
    countsByCategory: $birthsByDecadePlot,
    project: static function (int|string $decade, int|float $count) use ($birthsByDecadeBinSize): array {
        $startDecade = (int) $decade;

        return [
            'categoryLabel' => DecadeName::for($startDecade),
            'tooltipBody'   => I18N::plural('%s birth', '%s births', (int) $count, I18N::number($count)),
            'tooltipLabel'  => DecadeName::longLabel($startDecade, $birthsByDecadeBinSize),
        ];
    },
);

$mortalityByCentury = [];
$mortalityTooltips  = [];

foreach ($childMortalityByCentury as $entry) {
    $century                      = (int) $entry['century'];
    $mortalityByCentury[$century] = (float) $entry['rate'];
    $mortalityTooltips[$century]  = I18N::translate(
        '%1$s%% — %2$s of %3$s children died before age 5',
        I18N::number((float) $entry['rate'], 1),
        I18N::number((int) $entry['died']),
        I18N::number((int) $entry['total']),
    );
}

$childMortalityPayload = LineChartPayload::singleSeries(
    seriesName: I18N::translate('Mortality rate'),
    countsByCategory: $mortalityByCentury,
    project: static function (int|string $century, int|float $rate) use ($mortalityTooltips): array {
        $label = CenturyName::for((int) $century);

        return [
            // Append the locale-specific "Jh." abbreviation so the x-axis
            // reads "16. Jh." instead of just "16." (DE) / "16th cent."
            // instead of "16th" (EN), matching the mockup tick style.
            'categoryLabel' => I18N::translate('%s cent.', $label),
            'tooltipBody'   => $mortalityTooltips[$century] ?? '',
            'tooltipLabel'  => CenturyName::longLabel($label),
        ];
    },
);

$childMortalityExplanation = I18N::translate(
    'For every individual with both a birth and a death date the widget computes the number of days lived. A death within five years (1826 days) of birth counts as under-5 mortality. The line groups those children by their birth century so the historical decline becomes visible (typical 1700s value 30 to 40 percent, modern below 2 percent). Individuals with only a birth or only a death date are silently excluded, since the rate cannot be determined without both anchors. Per-century cohorts below 5 children are suppressed because a single dead child would spike the line by more than 10 percentage points.'
);

$childMortalityPeakExplanation = I18N::translate(
    'The single birth century with the highest under-5 mortality rate across the tree. Computed from the same per-individual BIRT+DEAT pairs as the per-century breakdown; cohorts below 5 children are suppressed so a single tragedy does not pin the peak.'
);

// Cohort with the highest under-5 mortality rate — feeds the
// adjacent "Peak value" Scalar card. Sorted descending by rate so
// the first entry is the worst century.
$childMortalityPeak = null;

foreach ($childMortalityByCentury as $entry) {
    if (($childMortalityPeak === null) || ((float) $entry['rate'] > (float) $childMortalityPeak['rate'])) {
        $childMortalityPeak = $entry;
    }
}

// Convert the band → count map into the row-of-objects shape that
// the chart-lib BarChart payload expects. Empty bands are kept —
// the chart renders a 1-px stub on the baseline so the tick still
// communicates "nobody in this band" instead of dropping silently.
$ageAtDeathBars = [];

foreach ($ageAtDeath as $bandLabel => $count) {
    $ageAtDeathBars[] = [
        'label'        => (string) $bandLabel,
        'value'        => (int) $count,
        'tooltipLabel' => I18N::translate('%s years', (string) $bandLabel),
        'tooltip'      => I18N::plural('%s person', '%s persons', (int) $count, I18N::number($count)),
    ];
}

// Cap the rendered bar count so labels and value-overlays stay
// readable. The card hosts the histogram in a 4-col grid slot
// (~230 px wide); ~14 bars is the densest layout where axis ticks
// and value labels do not overlap. Inner buckets stay even when
// trimmed centuries fall away. Track the pre/post counts so the
// card body can disclose how many low-outlier centuries were
// dropped from the visible range.
$birthsByCenturyFullCount = count($birthsByCentury);
$deathsByCenturyFullCount = count($deathsByCentury);
$birthsByCentury          = HistogramTrim::capByOutlierTrim($birthsByCentury, 14);
$deathsByCentury          = HistogramTrim::capByOutlierTrim($deathsByCentury, 14);
$birthsByCenturyDropped   = $birthsByCenturyFullCount - count($birthsByCentury);
$deathsByCenturyDropped   = $deathsByCenturyFullCount - count($deathsByCentury);

$birthsByCenturyBars = CenturyBarRowMapper::births($birthsByCentury);

$deathsByCenturyBars = CenturyBarRowMapper::deaths($deathsByCentury);

// Boxplot rows: one entry per surviving cohort, raw integer ages
// per individual. Chart-lib computes quartiles + whiskers itself.
$ageDistBoxes = [];

foreach ($ageDistByCentury as $entry) {
    $centuryLabel   = CenturyName::for($entry['century']);
    $ageDistBoxes[] = [
        'category'     => $centuryLabel,
        'tooltipLabel' => CenturyName::longLabel($centuryLabel),
        'values'       => $entry['values'],
    ];
}

$aboutThisChart = I18N::translate('About this chart');

if ($winterPeakScore === null) {
    $winterPeakCardBody = EmptyStatePlaceholder::render();
} else {
    $winterPeakDeviation = ($winterPeakScore->score - 1.0) * 100.0;
    $winterPeakCaption   = match (true) {
        $winterPeakDeviation > 0.5 => I18N::translate(
            'Winter months show a %s%% higher mortality density than the annual average.',
            I18N::number(abs($winterPeakDeviation), 0),
        ),
        $winterPeakDeviation < -0.5 => I18N::translate(
            'Winter months show a %s%% lower mortality density than the annual average.',
            I18N::number(abs($winterPeakDeviation), 0),
        ),
        default => I18N::translate('Deaths are evenly spread across the year.'),
    };

    // Multiplier sigil stays inline with the serif value so the
    // "× 0,84" reads as a single ratio token; Scalar's optional
    // `unit` slot is reserved for trailing units (e.g. years, %),
    // not leading sigils.
    $winterPeakCardBody = Component::scalar($module)
        ->with('value', '× ' . I18N::number($winterPeakScore->score, 2))
        ->with('unit', null)
        ->with('caption', $winterPeakCaption)
        ->render();
}
?>
<div class="wt-stat-grid">
<?php
echo Section::create(I18N::translate('How long was the life?'))
    ->withKicker(I18N::translate('Lifespan'))
    ->withSub(I18N::translate('Age at death, longevity and life-stage of the living'))
    ->render();

echo Card::for($module, I18N::translate('Age at death (10-year bands)'))
    ->withSub(I18N::plural('%s individual with both birth and death dates', '%s individuals with both birth and death dates', $totalAgeAtDeath, I18N::number($totalAgeAtDeath)))
    ->withEyebrow(I18N::translate('Distribution'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Hourglass)
    ->withSpan(8)
    ->withBodyHtml(
        Widget::barChart($module, 'age-at-death-bars')
            ->withData($ageAtDeathBars)
            ->withHeight(260)
            ->withAriaLabel(I18N::translate('Age at death distribution'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Life-stage (living)'))
    ->withSub(I18N::plural('%s living individual with a birth date', '%s living individuals with a birth date', $totalLivingBanded, I18N::number($totalLivingBanded)))
    ->withEyebrow(I18N::translate('Today living'))
    ->withAccent(Accent::Sage)
    ->withIllustration(Illustration::Candle)
    ->withSpan(4)
    ->withBodyHtml(
        Widget::donutChart($module, 'living-age-band-donut')
            ->withData($livingByAgeBand)
            ->with('centerLabel', I18N::translate('living'))
            ->withLegendPosition(LegendPosition::Bottom)
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Age-at-death distribution by century'))
    ->withSub(I18N::translate('Median, inter-quartile range and whiskers per birth century'))
    ->withEyebrow(I18N::translate('Distribution'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Hourglass)
    ->withInfo(
        I18N::translate('One box per birth century summarises how old people in that cohort lived to be. The dark line in the middle marks the typical age at death (the median). The box itself covers the middle 50 %% of the cohort. Its lower edge is the age below which a quarter died (P25), its upper edge the age below which three quarters died (P75). The thin lines extending up and down (the "whiskers") reach roughly to the youngest and oldest case still close to the box, formally the most extreme age within 1.5 box-heights of the edge. Individual dots beyond the whiskers are rare extreme cases. Very young child deaths cluster low, centenarians at the top. Cohorts smaller than five individuals are hidden because a single life cannot represent a century.'),
        $aboutThisChart,
        $aboutThisChart,
    )
    ->withSpan(8)
    ->withBodyHtml(
        Widget::boxPlot($module, 'age-at-death-boxplot')
            ->withData($ageDistBoxes)
            ->withHeight(300)
            ->withAriaLabel(I18N::translate('Age-at-death distribution by century'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Average lifespan by sex × century'))
    ->withSub(I18N::translate('Age at death per birth century, split by sex'))
    ->withEyebrow(I18N::translate('Timeline'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Hourglass)
    ->withSpan(12)
    ->withBodyHtml(
        Widget::lineChart($module, 'lifespan-by-sex-century')
            ->withData($lifespanBySexCentury)
            ->withHeight(280)
            ->withAriaLabel(I18N::translate('Average lifespan by sex and century'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Survival curve'))
    ->withSub(I18N::translate('Share of a birth cohort still alive at each age threshold'))
    ->withEyebrow(I18N::translate('Demographics'))
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::Hourglass)
    ->withInfo(
        I18N::translate('For every individual with both a birth and a death date recorded, the lifespan in whole years is derived. Each birth century forms one cohort and is sampled at ages 0, 10, 20, up to 100 — the value at age N is the share of the cohort that lived at least N years. Cohorts below 30 recorded individuals are dropped because a single death would shift the curve by more than three percentage points.'),
        $aboutThisChart,
        $aboutThisChart,
    )
    ->withSpan(12)
    ->withBodyHtml(
        Widget::lineChart($module, 'survival-curve')
            ->withData($survivalByCentury)
            ->with('yUnit', ' %')
            ->withAriaLabel(I18N::translate('Survival curve per birth century'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Top 10 oldest (deceased)'))
    ->withSub(I18N::translate('Age in years at death, longest-lived first'))
    ->withEyebrow(I18N::translate('Longevity'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Trophy)
    ->withSpan(6)
    ->withBodyHtml(
        Component::podium($module)
            ->with('class', 'progress-oldest-deceased')
            ->withData($topOldestDeceased)
            ->with('suffix', I18N::translate('yr'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Top 10 oldest (living)'))
    ->withSub(I18N::translate('Current age, oldest first'))
    ->withEyebrow(I18N::translate('Longevity'))
    ->withAccent(Accent::Sage)
    ->withIllustration(Illustration::Trophy)
    ->withSpan(6)
    ->withBodyHtml(
        Component::podium($module)
            ->with('class', 'progress-oldest-living')
            ->withData($topOldestLiving)
            ->with('suffix', I18N::translate('yr'))
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('Causes of death and infant mortality'))
    ->withKicker(I18N::translate('Mortality'))
    ->withSub(I18N::translate('What the recorded individuals died of'))
    ->render();

echo Card::for($module, I18N::translate('Common causes of death'))
    ->withSub(I18N::translate('%s distinct causes (top 15)', I18N::number($totalDeathCauses)))
    ->withEyebrow(I18N::translate('Causes'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Candle)
    ->withSpan(12)
    ->withBodyHtml(
        Component::progressList($module)
            ->with('class', 'progress-death-causes')
            ->withData($topDeathCauses)
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Child mortality (under 5)'))
    ->withSub(I18N::translate('Mortality rate per birth century'))
    ->withEyebrow(I18N::translate('Mortality'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Child)
    ->withInfo($childMortalityExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(8)
    ->withBodyHtml(
        (($childMortality === null) || ($childMortalityPayload->categories === []))
            ? EmptyStatePlaceholder::render()
            : Widget::lineChart($module, 'child-mortality-century-line')
                 ->withData($childMortalityPayload)
                 ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Peak value'))
    ->withSub($childMortalityPeak !== null
        ? I18N::translate('Child mortality %s century', CenturyName::for((int) $childMortalityPeak['century']))
        : null)
    ->withEyebrow(I18N::translate('Extreme'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Candle)
    ->withInfo($childMortalityPeakExplanation, $aboutThisChart, $aboutThisChart)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml(
        ($childMortalityPeak === null)
            ? EmptyStatePlaceholder::render()
            : Component::scalar($module)
                 ->with('value', I18N::number((float) $childMortalityPeak['rate'], 1))
                 ->with('unit', '%')
                 ->with('caption', I18N::translate(
                     '%1$s of %2$s children died before age 5 — the darkest cohort in the tree.',
                     I18N::number((int) $childMortalityPeak['died']),
                     I18N::number((int) $childMortalityPeak['total']),
                 ))
                 ->render()
    )
    ->render();

echo Section::create(I18N::translate('When were they born?'))
    ->withKicker(I18N::translate('Births'))
    ->withSub(I18N::translate('Time-distribution of births'))
    ->render();

echo Card::for($module, $birthsByDecadeCardTitle)
    ->withSub($birthsByDecadeCardSub)
    ->withEyebrow(I18N::translate('Timeline'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Sunrise)
    ->withSpan(12)
    ->withBodyHtml(
        Widget::lineChart($module, 'births-decade-line')
            ->withData($birthsByDecadePayload)
            ->withHeight(240)
            ->with('showArea', true)
            ->render()
    )
    ->render();

$birthsByCenturySub = I18N::plural('%s individual with a recorded birth year', '%s individuals with a recorded birth year', $totalBirthsByCentury, I18N::number($totalBirthsByCentury));

if ($birthsByCenturyDropped > 0) {
    $birthsByCenturySub .= ' — ' . I18N::plural(
        '%s outlier century not shown',
        '%s outlier centuries not shown',
        $birthsByCenturyDropped,
        I18N::number($birthsByCenturyDropped),
    );
}

echo Card::for($module, I18N::translate('Births by century'))
    ->withSub($birthsByCenturySub)
    ->withEyebrow(I18N::translate('Timeline'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Sunrise)
    ->withSpan(4)
    ->withBodyHtml(
        Widget::barChart($module, 'births-century-bars')
            ->withData($birthsByCenturyBars)
            ->withHeight(200)
            ->withAriaLabel(I18N::translate('Births per century'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Births by month'))
    ->withSub(I18N::plural('%s individual with a recorded birth month', '%s individuals with a recorded birth month', $totalBirthsByMonth, I18N::number($totalBirthsByMonth)))
    ->withEyebrow(I18N::translate('Month clock'))
    ->withAccent(Accent::Ochre)
    ->withIllustration(Illustration::Sunrise)
    ->withSpan(4)
    ->withBodyHtml(
        Widget::monthRadial($module)
            ->withData($birthsByMonth)
            ->withAccent(Accent::Ochre)
            ->with('centerLabel', I18N::translate('peak month'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Zodiac signs'))
    ->withSub(I18N::plural('%s individual with a known zodiac sign', '%s individuals with a known zodiac sign', $totalBirthsByZodiac, I18N::number($totalBirthsByZodiac)))
    ->withEyebrow(I18N::translate('Zodiac'))
    ->withAccent(Accent::Slate)
    ->withIllustration(Illustration::Zodiac)
    ->withSpan(4)
    ->withBodyHtml(
        Widget::monthRadial($module)
            ->withData($birthsByZodiacSign)
            ->withAccent(Accent::Slate)
            ->with('centerLabel', I18N::translate('peak sign'))
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('When did they die?'))
    ->withKicker(I18N::translate('Deaths'))
    ->withSub(I18N::translate('Season and century of recorded deaths'))
    ->render();

$deathsByCenturySub = I18N::plural('%s individual with a recorded death year', '%s individuals with a recorded death year', $totalDeathsByCentury, I18N::number($totalDeathsByCentury));

if ($deathsByCenturyDropped > 0) {
    $deathsByCenturySub .= ' — ' . I18N::plural(
        '%s outlier century not shown',
        '%s outlier centuries not shown',
        $deathsByCenturyDropped,
        I18N::number($deathsByCenturyDropped),
    );
}

echo Card::for($module, I18N::translate('Deaths by century'))
    ->withSub($deathsByCenturySub)
    ->withEyebrow(I18N::translate('Timeline'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Moon)
    ->withSpan(4)
    ->withBodyHtml(
        Widget::barChart($module, 'deaths-century-bars')
            ->withData($deathsByCenturyBars)
            ->withHeight(200)
            ->withAriaLabel(I18N::translate('Deaths per century'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Deaths by month'))
    ->withSub(I18N::plural('%s individual with a recorded death month', '%s individuals with a recorded death month', $totalDeathsByMonth, I18N::number($totalDeathsByMonth)))
    ->withEyebrow(I18N::translate('Month clock'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Moon)
    ->withSpan(4)
    ->withBodyHtml(
        Widget::monthRadial($module)
            ->withData($deathsByMonth)
            ->withAccent(Accent::Wine)
            ->with('centerLabel', I18N::translate('peak month'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Winter-peak score'))
    ->withSub(I18N::translate('Dec – Feb vs. baseline'))
    ->withEyebrow(I18N::translate('Season'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Moon)
    ->withSpan(4)
    ->centered()
    ->withBodyHtml($winterPeakCardBody)
    ->render();
?>
</div>

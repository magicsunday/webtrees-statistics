    ->render();

$deathsByCenturySub = I18N::plural('%s individual with a recorded death year', '%s individuals with a recorded death year', $totalDeathsByCentury, I18N::number($totalDeathsByCentury));

if ($deathsByCenturyDropped > 0) {
    $deathsByCenturySub .= ' — ' . I18N::plural(
        '%s outlier century not shown',
        '%s outlier centuries not shown',
        $deathsByCenturyDropped,
        I18N::number($deathsByCenturyDropped),
    );
}

echo Card::for($module, I18N::translate('Deaths by century'))
    ->withSub($deathsByCenturySub)
    ->withEyebrow(I18N::translate('Timeline'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Moon)
    ->withSpan(4)
    ->withBodyHtml(
        Widget::barChart($module, 'deaths-century-bars')

    ->withBodyHtml(
        (($childMortality === null) || ($childMortalityPayload->categories === []))
            ? EmptyStatePlaceholder::render()
            : Widget::lineChart($module, 'child-mortality-century-line')
                 ->withData($childMortalityPayload)
                 ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Peak value'))
    ->withSub($childMortalityPeak !== null
        ? I18N::translate('Child mortality %s century', CenturyName::for((int) $childMortalityPeak['century']))
        : null)
    ->withEyebrow(I18N::translate('Extreme'))

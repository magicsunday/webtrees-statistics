    ->withEyebrow(I18N::translate('Life event'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Rings)
    ->withInfo(
        I18N::translate(
            'Age at first marriage. The mirror axis separates husbands and wives, as shown by the labels at each side. Both sides share the same age bands, so the two distributions can be compared at a glance.'

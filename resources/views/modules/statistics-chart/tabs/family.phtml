/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
[$ageAtMarriageM, $ageAtMarriageF]     = $statistic->getTrimmedAgeAtMarriageDistributions();
[$ageAtFirstChildM, $ageAtFirstChildF] = $statistic->getTrimmedAgeAtFirstChildDistributions();
[$divorceAgeM, $divorceAgeF]           = $statistic->getTrimmedAgeAtDivorceDistributions();

$duration  = $statistic->getMarriageDurationDistribution();
$ageGap    = $statistic->getCoupleAgeGapDistribution();
$byCentury = $statistic->getWeddingsByCentury();
$byMonth   = $statistic->getWeddingsByMonth();

$divorcesByCentury = $statistic->getDivorcesByCentury();
$divorcesByMonth   = $statistic->getDivorcesByMonth();
$cohortRates       = $statistic->getDivorceRateByMarriageCohort();

$avgChildren             = $statistic->getAverageChildrenPerFamily();
$childrenHistogram       = $statistic->getChildrenPerFamilyDistribution();
$familySizeStackedDecade = $statistic->getFamilySizeStackedByDecade();
$averageFamilySizeLine   = $statistic->getAverageFamilySizeByCentury();
$multipleBirthRate       = $statistic->getMultipleBirthRateByCentury();
$siblingGaps             = $statistic->getSiblingAgeGapDistribution();
$largestFamilies         = $statistic->getTopLargestFamilies(10);
$grandchildFamilies      = $statistic->getTopGrandchildFamilies(10);

$sexRatioAnomalies        = $statistic->getSexRatioAnomalies();
$marriageDurationExtremes = $statistic->getMarriageDurationExtremes();
$childlessBreakdown       = $statistic->getChildlessFamiliesDistribution();
$firstChildMonth          = $statistic->getFirstChildrenByMonth();
$firstChildAgeByDecade    = $statistic->getAgeAtFirstChildMeanByDecade();

$totalAgeM             = array_sum($ageAtMarriageM);
$totalAgeF             = array_sum($ageAtMarriageF);
$totalDur              = array_sum($duration);
$totalAgeGap           = array_sum(array_map(static fn (array $band): int => $band['left'] + $band['right'], $ageGap));
$totalCentury          = array_sum($byCentury);
$totalMonth            = array_sum($byMonth);
$totalDivCentury       = array_sum($divorcesByCentury);
$totalDivMonth         = array_sum($divorcesByMonth);
$totalDivAgeM          = array_sum($divorceAgeM);
$totalDivAgeF          = array_sum($divorceAgeF);
$totalChildrenFamilies = array_sum($childrenHistogram);
$totalSiblingPairs     = array_sum($siblingGaps);
$totalFirstChildMonth  = array_sum($firstChildMonth);
$totalFirstChildM      = array_sum($ageAtFirstChildM);
$totalFirstChildF      = array_sum($ageAtFirstChildF);

$weddingsByCenturyBars = CenturyBarRowMapper::marriages($byCentury);
$divorcesByCenturyBars = CenturyBarRowMapper::divorces($divorcesByCentury);

// Pre-built MirrorHistogram rows — the named factory methods keep
// the `I18N::plural(...)` calls literal so xgettext picks the
// husband / wife / father / mother / man / woman msgids up.
$ageAtMarriageMRows   = MirrorBandRowMapper::husbands($ageAtMarriageM);
$ageAtMarriageFRows   = MirrorBandRowMapper::wives($ageAtMarriageF);
$ageAtFirstChildMRows = MirrorBandRowMapper::fathers($ageAtFirstChildM);
$ageAtFirstChildFRows = MirrorBandRowMapper::mothers($ageAtFirstChildF);
$divorceAgeMRows      = MirrorBandRowMapper::men($divorceAgeM);
$divorceAgeFRows      = MirrorBandRowMapper::women($divorceAgeF);

$divorceCohortSeries = DivorceCohortRowMapper::toLineSeries($cohortRates);
$cohortCategories    = $divorceCohortSeries['categories'];
$cohortValues        = $divorceCohortSeries['values'];
$cohortTooltips      = $divorceCohortSeries['tooltips'];
$cohortTooltipLabels = $divorceCohortSeries['tooltipLabels'];

$durationRows = [];

foreach ($duration as $label => $count) {
    $durationRows[] = [
        'label'        => $label,
        'value'        => (int) $count,
        'tooltipLabel' => I18N::translate('%s years', $label),
        'tooltip'      => I18N::plural('%s marriage', '%s marriages', $count, I18N::number($count)),
    ];
}

$widowhoodDistribution = $statistic->getWidowhoodYearsDistribution();
$totalWidowhood        = array_sum($widowhoodDistribution);

$widowhoodRows = [];

foreach ($widowhoodDistribution as $label => $count) {
    $widowhoodRows[] = [
        'label'        => $label,
        'value'        => (int) $count,
        'tooltipLabel' => I18N::translate('%s years', $label),
        'tooltip'      => I18N::plural('%s couple', '%s couples', $count, I18N::number($count)),
    ];
}

$remarriageIntervalDistribution = $statistic->getRemarriageIntervalDistribution();

$remarriageIntervalRows = [];

foreach ($remarriageIntervalDistribution as $label => $count) {
    $remarriageIntervalRows[] = [
        'label'        => $label,
        'value'        => (int) $count,
        'tooltipLabel' => I18N::translate('%s months', $label),
        'tooltip'      => I18N::plural('%s remarriage', '%s remarriages', $count, I18N::number($count)),
    ];
}

$ageGapModel = CoupleAgeGapRowMapper::toModel($ageGap);

$childrenPerFamilyBars = [];

foreach ($childrenHistogram as $bucket => $count) {
    $bucketCount             = (int) $count;
    $childrenPerFamilyBars[] = [
        'label'        => (string) $bucket,
        'value'        => $bucketCount,
        'tooltipLabel' => I18N::translate('%s children', (string) $bucket),
        'tooltip'      => I18N::plural('%s family', '%s families', $bucketCount, I18N::number($bucketCount)),
    ];
}

$aboutThisChart = I18N::translate('About this chart');
?>
<div class="wt-stat-grid">
<?php
echo Section::create(I18N::translate('When and whom they married'))
    ->withKicker(I18N::translate('Marriage'))
    ->withSub(I18N::translate('Age at marriage, duration and the age gap between the spouses'))
    ->render();


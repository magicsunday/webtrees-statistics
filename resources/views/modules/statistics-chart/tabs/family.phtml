            ->with('bottomLabel', I18N::translate('Women'))
            ->render()
    )
    ->render();

echo Section::create(I18N::translate("After the partner's death"))
    ->withKicker(I18N::translate('Widowhood'))
    ->withSub(I18N::translate('How long the surviving spouse outlived the first-deceased partner'))
    ->render();

echo Card::for($module, I18N::translate('Widowhood interval'))
    ->withSub(I18N::plural("%s couple with both partners' death dates recorded", "%s couples with both partners' death dates recorded", $totalWidowhood, I18N::number($totalWidowhood)))
    ->withEyebrow(I18N::translate('Life span'))
    ->withAccent(Accent::Deceased)
    ->withIllustration(Illustration::Candle)
    ->withInfo(
        I18N::translate(
            'For every couple where both spouses carry a recorded date of death, the gap in whole years between the two death dates lands the couple in a 5-year band. The 50+ band captures the long tail. Couples where neither spouse has a recorded death date are excluded — the interval is undefined without both anchors.'
        ),
        $aboutThisChart,
        $aboutThisChart
    )
    ->withSpan(6)
    ->withBodyHtml(
        Widget::barChart($module, 'widowhood-interval-bars')
            ->withData($widowhoodRows)
            ->with('xLabel', I18N::translate('Years'))
            ->withAriaLabel(I18N::translate('Widowhood interval'))
            ->render()
    )
    ->render();

echo Card::for($module, I18N::translate('Mourning period'))
    ->withSub(I18N::translate('Months between widowhood and the next marriage'))
    ->withEyebrow(I18N::translate('Life event'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Bell)
    ->withInfo(
        I18N::translate(
            'For a survivor whose spouse died and who later married again, the gap in whole months between that death and the next marriage. The first mourning year is split at six months — the window where convention bites hardest — then whole years up to a 60+ tail. A short interval can hint at the social conventions of the time. Unions that ended in divorce, and widowed spouses who never married again, are excluded.'
        ),
        $aboutThisChart,
        $aboutThisChart
    )
    ->withSpan(6)
    ->withBodyHtml(
        Widget::barChart($module, 'remarriage-interval-bars')
            ->withData($remarriageIntervalRows)
            ->with('xLabel', I18N::translate('Months'))
            ->withAriaLabel(I18N::translate('Mourning period'))
            ->render()
    )
    ->render();

echo Section::create(I18N::translate('Outlier marriages'))
    ->withKicker(I18N::translate('Extremes'))
    ->withSub(I18N::translate('The shortest- and longest-lasting marriages in the tree'))
    ->render();

echo Card::for($module, I18N::translate('Shortest & longest marriages'))
    ->withSub(I18N::translate('By duration · with how each marriage ended'))
    ->withEyebrow(I18N::translate('Extremes'))
    ->withAccent(Accent::Wine)
    ->withIllustration(Illustration::Rings)
    ->withInfo(
        I18N::translate(
            'The shortest- and longest-lasting marriages where the end is datable — either a recorded divorce or the earlier death of a spouse. Each marriage is measured from the wedding to that first ending event and labelled with how it ended. Marriages spanning more than 90 years are treated as data errors and left out.'
        ),
        $aboutThisChart,
        $aboutThisChart
    )
    ->withSpan(12)
    ->withBodyHtml(
        Component::marriageExtremes($module)
            ->withData($marriageDurationExtremes)
            ->render()
    )
    ->render();
?>

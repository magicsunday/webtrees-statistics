declare(strict_types=1);

use Fisharebest\Webtrees\Tree;
use Fisharebest\Webtrees\View;

/**
 * @var Tree                 $tree       The current tree
 * @var array<string,string> $tabs
 * @var string               $module     The name of the module
 * @var string               $title
 * @var string               $javascript The javascript library to use
 * @var string               $stylesheet URL of the module-wide stylesheet
 */
?>

<?php View::push('styles'); ?>
<link rel="stylesheet" href="<?php echo e($stylesheet); ?>">
<?php View::endpush(); ?>

<h2 class="wt-page-title">
    <?php echo $title; ?>
</h2>

<div class="wt-page-content wt-chart wt-statistics-chart" id="statistics-tabs">
    <ul class="nav nav-tabs mb-3" role="tablist">
        <?php foreach ($tabs as $label => $url) { ?>
            <?php $hash = e(md5($url)); ?>
            <li class="nav-item" role="presentation">
                <a class="nav-link"
                        id="<?php echo $hash; ?>-tab"
                        href="#tab-<?php echo $hash; ?>"
                        data-bs-toggle="tab"
                        data-wt-href="<?php echo e($url); ?>"
                        role="tab"
                        aria-controls="tab-<?php echo $hash; ?>"
                        aria-selected="false"
                >
                    <?php echo $label; ?>
                </a>
            </li>
        <?php } ?>
    </ul>

    <div class="tab-content">
        <?php foreach ($tabs as $url) { ?>
            <?php $hash = e(md5($url)); ?>
            <div class="tab-pane fade wt-ajax-load"
                 role="tabpanel"
                 id="tab-<?php echo $hash; ?>"
                 aria-labelledby="<?php echo $hash; ?>-tab"></div>
        <?php } ?>
    </div>
</div>

<?php View::push('javascript'); ?>
<script>

'use strict';

// Bootstrap tabs — load content dynamically using AJAX, then run
// the widget dispatcher on the freshly-injected pane so every
// `[data-widget]` element inside it gets rendered.
$('#statistics-tabs a[data-bs-toggle="tab"][data-wt-href]').on("show.bs.tab", function () {
    $(this.getAttribute("href") + ":empty").load(this.dataset.wtHref, function () {
        if (window.WebtreesStatistic && typeof window.WebtreesStatistic.renderWidgets === "function") {
            window.WebtreesStatistic.renderWidgets(this);
        }
    });
});

// If the URL contains a fragment, then activate the corresponding tab.
// Use a prefix on the fragment, to prevent scrolling to the element.
let target = window.location.hash.replace("tab-", "");
let tab = document.querySelector("#statistics-tabs .nav-link[href='" + target + "']");

// If not, then activate the first tab.
tab = tab ?? document.querySelector("#statistics-tabs .nav-link");
tab.click();

// If the user selects a tab, update the URL to reflect this
$('#statistics-tabs a[data-bs-toggle="tab"]').on("shown.bs.tab", function (e) {
    window.location.hash = "tab-" + e.target.href.substring(e.target.href.indexOf('#') + 1);
});

</script>
<?php View::endpush(); ?>


<?php View::push('javascript'); ?>
<script src="<?php echo e($javascript); ?>"></script>
<?php View::endpush(); ?>

<?php View::push('javascript'); ?>
<script>

'use strict';

// Bootstrap tabs — load content dynamically using AJAX, then run
// the widget dispatcher on the freshly-injected pane so every
// `[data-widget]` element inside it gets rendered.
$('#statistics-tabs a[data-bs-toggle="tab"][data-wt-href]').on("show.bs.tab", function () {
    $(this.getAttribute("href") + ":empty").load(this.dataset.wtHref, function () {
        if (window.WebtreesStatistic && typeof window.WebtreesStatistic.renderWidgets === "function") {
            window.WebtreesStatistic.renderWidgets(this);
        }
    });
});

// If the URL contains a fragment, then activate the corresponding tab.
// Use a prefix on the fragment, to prevent scrolling to the element.
let target = window.location.hash.replace("tab-", "");
let tab = document.querySelector("#statistics-tabs .nav-link[href='" + target + "']");

// If not, then activate the first tab.
tab = tab ?? document.querySelector("#statistics-tabs .nav-link");
tab.click();

// If the user selects a tab, update the URL to reflect this
$('#statistics-tabs a[data-bs-toggle="tab"]').on("shown.bs.tab", function (e) {
    window.location.hash = "tab-" + e.target.href.substring(e.target.href.indexOf('#') + 1);
});

</script>

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$sourceCoverage = $statistic->getSourceCitationCoverage();
$gaps           = $statistic->getMissingEventGaps();
$generation     = $statistic->getAverageGenerationLength();
$birthsByDecade = $statistic->getBirthsByDecade();
$totalBirths    = array_sum($birthsByDecade);

// LineChart expects a list of {label, value, tooltip?} rows;
// convert from the map shape the repository returns and pre-format
// a pluralised tooltip per row so the hover surfaces "4 births"
// instead of a bare "4".
$birthsLineSeries = [];

foreach ($birthsByDecade as $decade => $count) {
    $birthsLineSeries[] = [
        'label'   => $decade,
        'value'   => $count,
        'tooltip' => I18N::plural('%s birth', '%s births', $count, I18N::number($count)),
    ];
}

// Show every 3rd decade label so axis stays legible on
// tree-spanning-centuries datasets.
$birthsXLabelEvery = max(1, (int) ceil(count($birthsLineSeries) / 12));

$plausibility = $statistic->getPlausibilitySummary();
$ruleLabels   = [
    'lifespan-over-limit'      => I18N::translate('Lifespan over plausibility ceiling'),
    'parent-age-out-of-range'  => I18N::translate('Parent age outside the plausible range'),
    'death-before-child-birth' => I18N::translate("Parent's death recorded before child's birth"),
    'marriage-before-birth'    => I18N::translate("Marriage recorded before a spouse's birth"),
    'sibling-interval'         => I18N::translate('Siblings born too close together or too far apart'),
];

$gapLabels = [
    'BIRT.event' => I18N::translate('Missing birth event'),
    'BIRT.place' => I18N::translate('Missing birth place'),
    'DEAT.event' => I18N::translate('Missing death event'),
    'DEAT.place' => I18N::translate('Missing death place'),
];

$gapRows = [];

foreach ($gaps as $gap) {
    $key       = $gap['event'] . '.' . $gap['kind'];
    $gapRows[] = [
        'label' => $gapLabels[$key] ?? ($gap['event'] . ' / ' . $gap['kind']),
        'value' => $gap['value'],
        'total' => $gap['total'],
    ];
}
?>
<div class="container">
    <div class="row row-cols-1 row-cols-md-2 g-3">
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Source-citation coverage'); ?></h5>
                    <small><?php echo I18N::translate('Individuals with at least one source linked to their record.'); ?></small>
                </div>
                <div class="card-body">
                    <?php
                        echo view(
                            $module . '::modules/statistics-chart/Partials/RateList',
                            [
                                'class' => 'progress-tree-health',
                                'data'  => [
                                    [
                                        'label' => I18N::translate('Documented individuals'),
                                        'value' => $sourceCoverage['value'],
                                        'total' => $sourceCoverage['total'],
                                    ],
                                ],
                            ],
                        );
?>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Average generation length'); ?></h5>
                    <small><?php echo I18N::translate('Mean parent-to-child birth-year delta across the whole tree.'); ?></small>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <?php
    echo view(
        $module . '::modules/statistics-chart/Partials/Scalar',
        [
            'value' => ($generation !== null)
                ? I18N::number((int) round($generation))
                : I18N::translate('no data'),
            'unit'    => ($generation !== null) ? I18N::translate('years') : null,
            'caption' => ($generation !== null)
                ? I18N::translate('Parent-to-child birth-year delta, averaged across every usable pair.')
                : I18N::translate('At least one parent-child pair with parseable birth dates is required.'),
        ],
    );
?>
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 g-3 mt-1 mb-3">
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Missing-event gaps'); ?></h5>
                    <small><?php echo I18N::translate('Share of individuals without a recorded birth or death event, with or without a place.'); ?></small>
                </div>
                <div class="card-body">
                    <?php
    echo view(
        $module . '::modules/statistics-chart/Partials/RateList',
        [
            'class' => 'progress-tree-health-gap',
            'data'  => $gapRows,
        ],
    );
?>
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 g-3 mt-1 mb-3">
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Tree growth — births per decade'); ?></h5>
                    <small><?php echo I18N::plural('%s recorded birth date across the visible decades', '%s recorded birth dates across the visible decades', $totalBirths, I18N::number($totalBirths)); ?></small>
                </div>
                <div class="card-body">
                    <?php
        echo view(
            $module . '::modules/statistics-chart/Partials/LineChart',
            [
                'identifier'  => 'tree-growth-line-chart',
                'data'        => $birthsLineSeries,
                'height'      => 260,
                'xLabelEvery' => $birthsXLabelEvery,
            ],
        );
?>
                </div>
            </div>
        </div>
    </div>

    <?php if ($plausibility['totalCount'] > 0) { ?>
    <div class="row row-cols-1 g-3 mt-1 mb-3">
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Plausibility checks'); ?></h5>
                    <small><?php echo I18N::plural('%s finding across all rules', '%s findings across all rules', $plausibility['totalCount'], I18N::number($plausibility['totalCount'])); ?></small>
                </div>
                <div class="card-body">
                    <?php foreach ($plausibility['perRule'] as $ruleSection) { ?>
                    <div class="wt-plausibility-rule mb-3">
                        <h6 class="mb-1">
                            <?php echo e($ruleLabels[$ruleSection['ruleId']] ?? $ruleSection['ruleId']); ?>
                            <small class="text-muted ms-2">(<?php echo I18N::number($ruleSection['count']); ?>)</small>
                        </h6>
                        <ul class="list-unstyled small mb-0">
                            <?php foreach ($ruleSection['examples'] as $example) { ?>
                            <li>
                                <?php if ($example->url !== null) { ?>
                                <a href="<?php echo e($example->url); ?>"><?php echo e($example->xref); ?></a>
                                <?php } else { ?>
                                <span><?php echo e($example->xref); ?></span>
                                <?php } ?>
                                <span class="text-muted ms-1"><?php echo e($example->reason); ?></span>
                            </li>
                            <?php } ?>
                        </ul>
                    </div>
                    <?php } ?>
                </div>
            </div>
        </div>
    </div>
    <?php } ?>
</div>

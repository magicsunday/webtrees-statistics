use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$sourceCoverage = $statistic->getSourceCitationCoverage();
$gaps           = $statistic->getMissingEventGaps();
$generation     = $statistic->getAverageGenerationLength();

$ancestorDistribution = $statistic->getAncestorCountDistribution();
$avgPedigree          = $statistic->getAveragePedigreeCompleteness();
$generationDepth      = $statistic->getGenerationDepthSummary();
$endogamy             = $statistic->getEndogamySummary();
$totalIndividuals     = $statistic->getTotalIndividuals();
$totalAncestorsRows   = array_sum($ancestorDistribution);

// BarChart rows for generation-depth distribution + known-ancestors
// distribution. Both render as histograms in design2 — switch from
// ProgressList to BarChart to match. tooltipLabel + tooltipBody are
// pre-built with literal I18N::plural calls so xgettext picks the
// strings up.
$generationDepthBars = [];

foreach ($generationDepth->distribution as $gen => $count) {
    $bucketCount           = (int) $count;
    $generationDepthBars[] = [
        'label'        => (string) $gen,
        'value'        => $bucketCount,
        'tooltipLabel' => I18N::plural('%s generation deep', '%s generations deep', (int) $gen, I18N::number((int) $gen)),
        'tooltip'      => I18N::plural('%s individual', '%s individuals', $bucketCount, I18N::number($bucketCount)),
    ];
}

$ancestorDistributionBars = [];

foreach ($ancestorDistribution as $bucket => $count) {
    $bucketCount                = (int) $count;
    $ancestorDistributionBars[] = [
        'label'        => (string) $bucket,
        'value'        => $bucketCount,
        'tooltipLabel' => I18N::translate('%s known ancestors', (string) $bucket),
        'tooltip'      => I18N::plural('%s individual', '%s individuals', $bucketCount, I18N::number($bucketCount)),
    ];
}

$gapLabels = [
    'BIRT.event' => I18N::translate('Missing birth event'),
    'BIRT.place' => I18N::translate('Missing birth place'),
    'DEAT.event' => I18N::translate('Missing death event'),
    'DEAT.place' => I18N::translate('Missing death place'),
    'MARR.event' => I18N::translate('Missing marriage event'),
    'MARR.place' => I18N::translate('Missing marriage place'),
];

$gapRows = [];

foreach ($gaps as $gap) {
    $key       = $gap['event'] . '.' . $gap['kind'];
    $gapRows[] = [
        'label' => $gapLabels[$key] ?? ($gap['event'] . ' / ' . $gap['kind']),
        'value' => $gap['value'],
        'total' => $gap['total'],
    ];
}

$sourcedPct      = ($sourceCoverage->total > 0) ? ($sourceCoverage->value / $sourceCoverage->total) * 100 : 0.0;
$completenessPct = $avgPedigree * 100;

$pedigreeExplanation = I18N::translate(
    'Each person in the tree has up to 30 possible direct ancestors within four generations (2 parents + 4 grandparents + 8 great-grandparents + 16 great-great-grandparents). The pedigree-completeness index (Lacy 1989) is the fraction of those 30 slots that are actually documented for that individual. The number shown here is the average across every individual in the tree.'
);

$generationDepthExplanation = I18N::translate(
    'The maximum generation depth is the longest unbroken parent-child chain recorded in the tree. The widget walks every individual upward, follows fathers and mothers in parallel, and reports the deepest verified line.'
);

$generationDepthDistributionExplanation = I18N::translate(
    'For every individual, this bucket counts how many generations of descendants are recorded below them in the tree. Bucket 0 = leaf (no descendants), bucket N = an individual whose deepest verified descendant is N generations younger.'
);

$endogamyExplanation = I18N::translate(
    'For every couple where both spouses have at least one parent recorded, the widget walks each spouse\'s ancestor tree up to four generations and intersects the two sets. A non-empty intersection means the couple share at least one common ancestor — the classic signature of cousin marriage and pedigree collapse.'
);
?>
<div class="wt-stat-grid">

    <?php echo view($module . '::modules/statistics-chart/Partials/Section', [
        'kicker' => I18N::translate('Documentation'),
        'title'  => I18N::translate('How well is the tree documented?'),
        'sub'    => I18N::translate('Source coverage, completeness and average generation length'),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Source-citation coverage'),
        'sub'          => I18N::translate('Individuals with at least one source'),
        'eyebrow'      => I18N::translate('Documentation'),
        'accent'       => 'var(--sage)',
        'illustration' => 'book',
        'span'         => 4,
        'centered'     => true,
        'showFooter'   => true,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/GaugeArc', [
            'value'   => $sourcedPct,
            'accent'  => 'var(--sage)',
            'label'   => I18N::translate('documented'),
            'meta'    => I18N::translate('%1$s of %2$s', I18N::number($sourceCoverage->value), I18N::number($sourceCoverage->total)),
            'caption' => I18N::translate('Individuals with ≥ 1 source citation'),
        ]),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Pedigree completeness'),
        'sub'          => I18N::translate('Lacy index — average share of known ancestors up to the 4th generation'),
        'eyebrow'      => I18N::translate('Completeness'),
        'accent'       => 'var(--wine)',
        'illustration' => 'magnifier',
        'info'         => $pedigreeExplanation,
        'span'         => 4,
        'centered'     => true,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/GaugeArc', [
            'value'   => $completenessPct,
            'accent'  => 'var(--wine)',
            'label'   => I18N::translate('Lacy 1989'),
            'meta'    => I18N::plural('%s individual sampled', '%s individuals sampled', $totalAncestorsRows, I18N::number($totalAncestorsRows)),
            'caption' => I18N::translate('Higher = more thorough research'),
        ]),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Generation length'),
        'sub'          => I18N::translate('Average birth-year gap parent → child'),
        'eyebrow'      => I18N::translate('Time'),
        'accent'       => 'var(--ochre)',
        'illustration' => 'hourglass',
        'span'         => 4,
        'centered'     => true,
        'showFooter'   => true,
        'bodyRenderer' => static function () use ($module, $generation): void {
            $hasData         = $generation !== null;
            $generationRound = $hasData ? round($generation, 1) : 0.0;

            echo view($module . '::modules/statistics-chart/Partials/Scalar', [
                // One decimal place so the user reads the actual
                // measurement instead of a rounded integer — "31,8"
                // instead of "32" makes it clear when a tree sits
                // just below the typical band.
                'value' => $hasData
                    ? I18N::number($generationRound, 1)
                    : I18N::translate('no data'),
                'unit'    => $hasData ? I18N::translate('years') : null,
                'caption' => $hasData
                    ? I18N::translate('Averaged across every parent-child pair with parseable birth dates.')
                    : I18N::translate('At least one parent-child pair with parseable birth dates is required.'),
                // Scale-track 20-40 years matches the design2 reference
                // (typical range for human reproductive generations).
                // The marker collapses into the rail when the value sits
                // outside the displayed band — the per-tree value is
                // still shown in full above the track.
                'scale' => $hasData
                    ? [
                        'label'   => I18N::translate('Typical range'),
                        'min'     => 20.0,
                        'max'     => 40.0,
                        'current' => $generationRound,
                        'ticks'   => ['20', '25', '30', '35', I18N::translate('40 yr')],
                    ]
                    : null,
            ]);
        },
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Section', [
        'kicker' => I18N::translate('Gaps'),
        'title'  => I18N::translate('What is missing?'),
        'sub'    => I18N::translate('Where the tree has gaps — events and places not recorded'),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Missing-event gaps'),
        'sub'          => I18N::translate('Share of individuals without a recorded birth, death or marriage event'),
        'eyebrow'      => I18N::translate('Gaps'),
        'accent'       => 'var(--wine)',
        'illustration' => 'magnifier',
        'span'         => 12,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/HeatStrip', [
            'rows' => $gapRows,
        ]),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Section', [
        'kicker' => I18N::translate('Structure'),
        'title'  => I18N::translate('How deep and branched is the tree?'),
        'sub'    => I18N::translate('Generation depth, ancestor distribution and kin marriages'),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Maximum generation depth'),
        'sub'          => I18N::translate('Longest line in the tree, leaf to oldest ancestor'),
        'eyebrow'      => I18N::translate('Depth'),
        'accent'       => 'var(--slate)',
        'illustration' => 'tree',
        'info'         => $generationDepthExplanation,
        'span'         => 4,
        'centered'     => true,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/Scalar', [
            'value'   => I18N::number($generationDepth->maxDepth),
            'unit'    => I18N::translate('generations'),
            'caption' => $generationDepth->capped
                ? I18N::translate('Walk reached the safety cap (20 generations) — check the tree for cyclic FAMC/FAMS edits.')
                : I18N::translate('Each step is one parent–child link upward.'),
        ]),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Generation depth distribution'),
        'sub'          => I18N::translate('Individuals N generations above their deepest descendant'),
        'eyebrow'      => I18N::translate('Structure'),
        'accent'       => 'var(--slate)',
        'illustration' => 'tree',
        'info'         => $generationDepthDistributionExplanation,
        'span'         => 8,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/BarChart', [
            'identifier' => 'generation-depth-bars',
            'data'       => $generationDepthBars,
            'ariaLabel'  => I18N::translate('Generation depth distribution'),
        ]),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Known ancestors per individual'),
        'sub'          => I18N::translate('Distinct ancestors up to 4 generations (max. 30)'),
        'eyebrow'      => I18N::translate('Ancestors'),
        'accent'       => 'var(--ochre)',
        'illustration' => 'family',
        'span'         => 8,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/BarChart', [
            'identifier' => 'ancestor-count-bars',
            'data'       => $ancestorDistributionBars,
            'ariaLabel'  => I18N::translate('Known ancestors per individual'),
        ]),
    ]); ?>

    <?php if ($endogamy !== null) { ?>
        <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
            'module'       => $module,
            'title'        => I18N::translate('Endogamy rate'),
            'sub'          => I18N::translate('Share of marriages within 4 generations'),
            'eyebrow'      => I18N::translate('Kinship'),
            'accent'       => 'var(--wine)',
            'illustration' => 'knot',
            'info'         => $endogamyExplanation,
            'span'         => 4,
            'centered'     => true,
            'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/Scalar', [
                'value'   => I18N::number($endogamy->rate, 1),
                'unit'    => '%',
                'caption' => I18N::plural(
                    '%1$s of %2$s couple where both spouses had at least one recorded parent share a common ancestor.',
                    '%1$s of %2$s couples where both spouses had at least one recorded parent share a common ancestor.',
                    $endogamy->total,
                    I18N::number($endogamy->endogamous),
                    I18N::number($endogamy->total),
                ),
            ]),
        ]); ?>
    <?php } ?>

</div>

            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Age at first child — fathers'); ?></h5>
                    <small><?php echo I18N::plural('%s father with a dated first child', '%s fathers with a dated first child', $totalFirstChildM, I18N::number($totalFirstChildM)); ?></small>

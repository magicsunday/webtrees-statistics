    <div class="row row-cols-1 row-cols-md-2 g-3">
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Marriage duration'); ?></h5>
                    <small><?php echo I18N::plural('%s couple with a measurable duration', '%s couples with a measurable duration', $totalDur, I18N::number($totalDur)); ?></small>
                </div>
                <div class="card-body">
                    <?php
    // Marriage-duration histogram reads better as a bar chart
    // with brush zoom — most marriages cluster in the 0-30 year
    // range and the long tail (60+) is interesting only when
    // the reader zooms in.
    // Tooltips on the BarChart need explicit unit labels — the
    // raw `{label: "0-9", value: 35}` reads as "what are 0-9?"
    // without context. `tooltipLabel` becomes the bold header
    // (years span), `tooltip` becomes the pluralised body.
    $durationRows = [];

foreach ($duration as $label => $count) {
    $durationRows[] = [
        'label' => $label,
        'value' => (int) $count,
        // `$label` is a range string like "0–9" or "60+", so the
        // unit suffix stays a sprintf placeholder rather than a
        // numeric plural form.
        'tooltipLabel' => I18N::translate('%s years', $label),
        'tooltip'      => I18N::plural('%s marriage', '%s marriages', $count, I18N::number($count)),
    ];
}

// Brush zoom intentionally off — the active d3-brush overlay
// captures every mouse event in the chart area (including
// hover), so the per-bar tooltip never fires when brush is on.
// Histograms with a small bucket count (e.g. marriage duration
// has 7 buckets) gain little from zoom and need working
// tooltips more.
echo view(
    $module . '::modules/statistics-chart/Partials/BarChart',
    [
        'identifier' => 'marriage-duration-bar',
        'data'       => $durationRows,
        'ariaLabel'  => I18N::translate('Marriage duration'),
    ],
);
?>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Couple age gap (husband − wife)'); ?></h5>
                    <small><?php echo I18N::plural('%s couple with both birth dates', '%s couples with both birth dates', $totalAgeGap, I18N::number($totalAgeGap)); ?></small>
                </div>
                <div class="card-body">
                    <?php
    // Convert the signed `{label => count}` map the repository
    // returns into the DivergingBar row shape — sign comes from
    // the label's leading character (`-` / `<` mark the negative
    // side, anything else is positive).
    $ageGapRows = [];

foreach ($ageGap as $label => $count) {
    $first        = $label !== '' ? $label[0] : '+';
    $isNegative   = $first === '-' || $first === '<';
    $ageGapRows[] = [
        'label'        => $label,
        'value'        => (int) $count,
        'sign'         => $isNegative ? -1 : 1,
        'tooltipLabel' => $isNegative
            ? I18N::translate('Wife older by %s years', $label)
            : I18N::translate('Husband older by %s years', $label),
        'tooltip' => I18N::plural('%s couple', '%s couples', $count, I18N::number($count)),
    ];
}

echo view(
    $module . '::modules/statistics-chart/Partials/DivergingBar',
    [
        'identifier' => 'couple-age-gap-diverging',
        'data'       => $ageGapRows,
        'ariaLabel'  => I18N::translate('Couple age gap (husband − wife)'),
    ],
);
?>
                </div>
            </div>
        </div>
    </div>


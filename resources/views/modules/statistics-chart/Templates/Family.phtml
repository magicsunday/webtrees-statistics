    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Average pedigree completeness'),
        'sub'          => I18N::translate('Lacy 1989 — mean fraction of direct ancestors known up to four generations across all individuals.'),
        'eyebrow'      => I18N::translate('COMPLETENESS'),
        'accent'       => 'var(--wine)',
        'illustration' => 'magnifier',
        'info'         => $pedigreeExplanation,
        'span'         => 4,
        'centered'     => true,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/Scalar', [
            'value'   => I18N::number($avgPedigree * 100, 1),
            'unit'    => '%',
            'caption' => I18N::plural('%s individual sampled', '%s individuals sampled', $totalAncestorsRows, I18N::number($totalAncestorsRows)),
        ]),
    ]); ?>

    <?php if ($generationDepth->maxDepth > 0) { ?>
        <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
            'module'       => $module,
            'title'        => I18N::translate('Maximum generation depth'),
            'sub'          => I18N::translate('Longest verified vertical chain from a leaf descendant up to its furthest ancestor.'),
            'eyebrow'      => I18N::translate('DEPTH'),
            'accent'       => 'var(--slate)',
            'illustration' => 'tree',
            'info'         => $generationDepthExplanation,
            'span'         => 4,
            'centered'     => true,
            'bodyRenderer' => static function () use ($module, $generationDepth): void {
                echo view($module . '::modules/statistics-chart/Partials/Scalar', [
                    'value'   => I18N::number($generationDepth->maxDepth),
                    'unit'    => I18N::translate('generations'),
                    'caption' => $generationDepth->capped
                        ? I18N::translate('Walk reached the safety cap (20 generations) — check the tree for cyclic FAMC/FAMS edits.')
                        : I18N::translate('Each step is one parent–child link upward; siblings, half-lines and dead-ends are merged into the longest path.'),
                ]);

                if ($generationDepth->chains !== []) {
                    echo '<div class="wt-generation-chains mt-3">';
                    echo '<div class="wt-generation-chain-label text-muted text-center small mb-2">';
                    echo I18N::plural(
                        'One verified chain at this depth:',
                        'Top %s verified chains at this depth (youngest leaf first):',
                        count($generationDepth->chains),
                        I18N::number(count($generationDepth->chains)),
                    );
                    echo '</div>';

                    foreach ($generationDepth->chains as $chain) {
                        echo '<ol class="wt-generation-chain-list list-unstyled mb-2 text-center">';

                        foreach ($chain as $index => $member) {
                            echo '<li><a href="' . e($member->url()) . '">' . $member->fullName() . '</a>';

                            if ($index < count($chain) - 1) {
                                echo '<span class="wt-generation-chain-sep" aria-hidden="true">→</span>';
                            }
                            echo '</li>';
                        }
                        echo '</ol>';
                    }
                    $additionalChainCount = $generationDepth->totalChainCount - count($generationDepth->chains);

                    if ($additionalChainCount > 0) {
                        echo '<div class="text-muted text-center small mt-1">';
                        echo I18N::plural(
                            '%s additional chain at the same depth not shown.',
                            '%s additional chains at the same depth not shown.',
                            $additionalChainCount,
                            I18N::number($additionalChainCount),
                        );
                        echo '</div>';
                    }
                    echo '</div>';
                }
            },
        ]); ?>

        <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
            'module'       => $module,
            'title'        => I18N::translate('Generation depth distribution'),
            'sub'          => I18N::translate('How many individuals sit at exactly N generations above their deepest recorded descendant.'),
            'eyebrow'      => I18N::translate('STRUCTURE'),
            'accent'       => 'var(--slate)',
            'illustration' => 'tree',
            'info'         => $generationDepthDistributionExplanation,
            'span'         => 8,
            'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/ProgressList', ['class' => 'progress-generation-depth', 'data' => $generationDepthDistribution]),
        ]); ?>
    <?php } ?>


        'categoryLabel' => (string) $century,
        'tooltipBody'   => I18N::plural('%s divorce', '%s divorces', (int) $count, I18N::number($count)),
        'tooltipLabel'  => CenturyName::longLabel((string) $century),
    ],
);

$cohortRatePercent = [];

foreach ($cohortRates as $cohort => $rate) {
    $cohortRatePercent[$cohort] = (int) round($rate * 100);
}

$cohortCategories = [];
$cohortValues     = [];
$cohortTooltips   = [];

foreach ($cohortRatePercent as $cohort => $percent) {
    $cohortCategories[] = I18N::translate('%ss', (string) $cohort);
    $cohortValues[]     = $percent;
    $cohortTooltips[]   = I18N::translate('%s%% divorced', I18N::number($percent));
}

$durationRows = [];

foreach ($duration as $label => $count) {
    $durationRows[] = [
        'label'        => $label,
        'value'        => (int) $count,
        'tooltipLabel' => I18N::translate('%s years', $label),
        'tooltip'      => I18N::plural('%s marriage', '%s marriages', $count, I18N::number($count)),
    ];
}

$ageGapRows = [];

foreach ($ageGap as $label => $count) {
    $first      = $label !== '' ? $label[0] : '+';
    $isNegative = ($first === '-') || ($first === '<');

    if ($isNegative) {
        if (str_starts_with($label, '<')) {
            $cleaned = '>' . substr($label, 2);
        } else {
            $parts = explode(' to ', $label);

            if (count($parts) === 2) {
                $lo      = abs((int) $parts[0]);
                $hi      = abs((int) $parts[1]);
                $cleaned = min($lo, $hi) . '–' . max($lo, $hi);
            } else {
                $cleaned = ltrim($label, '-');
            }
        }
    } else {
        $cleaned = $label;
    }

    $ageGapRows[] = [
        'label'        => $cleaned,
        'value'        => (int) $count,
        'sign'         => $isNegative ? -1 : 1,
        'tooltipLabel' => $isNegative
            ? I18N::translate('Husband older by %s years', $cleaned)
            : I18N::translate('Wife older by %s years', $cleaned),
        'tooltip' => I18N::plural('%s couple', '%s couples', $count, I18N::number($count)),
    ];
}

$pedigreeExplanation = I18N::translate(
    'Each person in the tree has up to 30 possible direct ancestors within four generations (2 parents + 4 grandparents + 8 great-grandparents + 16 great-great-grandparents). The pedigree-completeness index (Lacy 1989) is the fraction of those 30 slots that are actually documented for that individual. The number shown here is the average across every individual in the tree, so 12 percent means "on average each person has 12 percent of their 4-generation ancestry recorded". Higher = more thorough research; lower = many gaps. Caveats: pedigree-collapse duplicates (cousin marriages) are not deduplicated, recent leaf-imports without ancestors drag the average down, and only direct ancestors are counted — siblings / cousins are out of scope.'
);

$divorcesAgeBandExplain = I18N::translate(
    'Each bar is one century of recorded divorces. The segments split the bar into five life-stage age bands measured at the time of divorce (0–24, 25–34, 35–44, 45–54, 55+) plus an Unknown band for divorces with no usable birth date on either spouse. One tick per divorce, classified by the husband\'s age when present and the wife\'s age otherwise, so the per-century totals line up exactly with the divorces-by-century chart above. Hover any segment for the per-band count and the century total.'
);

$generationDepthExplanation = I18N::translate(
    'The maximum generation depth is the longest unbroken parent-child chain recorded in the tree. The widget walks every individual upward, follows fathers and mothers in parallel, and reports the deepest verified line. The distribution histogram on the right shows, for every individual, how many generations of descendants sit below them in the tree — so a value of 0 means a leaf (no recorded descendants), and the bucket at the maximum depth shows the eldest ancestors. A safety cap at 20 generations catches accidentally-cyclic GEDCOM edits.'
);

$generationDepthDistributionExplanation = I18N::translate(
    'For every individual, this bucket counts how many generations of descendants are recorded below them in the tree. Bucket 0 = leaf (no descendants), bucket N = an individual whose deepest verified descendant is N generations younger. The shape tells you whether the tree is broadly wide (many leaves, low depth) or has a few unusually deep verified lines (small tail at the upper end).'
);

$endogamyExplanation = I18N::translate(
    'For every couple where both spouses have at least one parent recorded, the widget walks each spouse\'s ancestor tree up to four generations (parents, grandparents, great-grandparents, great-great-grandparents) and intersects the two sets. A non-empty intersection means the couple share at least one common ancestor — the classic signature of cousin marriage and pedigree collapse, typical in rural pre-industrial populations and rare in well-mixed urban ones. Couples where at least one spouse has no recorded parents cannot be tested and are excluded from both numerator and denominator, so the rate stays honest.'
);

}

$divorceAgeMRows = [];

foreach ($divorceAgeM as $band => $count) {
    $bandCount         = (int) $count;
    $divorceAgeMRows[] = [
        'label'        => (string) $band,
        'value'        => $bandCount,
        'tooltipLabel' => I18N::translate('%s years', (string) $band),

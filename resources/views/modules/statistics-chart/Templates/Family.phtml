use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;
use MagicSunday\Webtrees\Statistic\Support\HistogramTrim;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$ageAtMarriageM = $statistic->getAgeAtMarriageDistribution('M');
$ageAtMarriageF = $statistic->getAgeAtMarriageDistribution('F');

// Trim leading / trailing buckets that are 0 in BOTH sex variants so
// the side-by-side histograms don't render rows like `0–4: 0` /
// `5–9: 0` that carry no information. Keeping a non-zero in either
// series preserves the bucket on both sides so the visual axis
// stays aligned.
[$ageAtMarriageM, $ageAtMarriageF] = HistogramTrim::dropCoZeroEnds($ageAtMarriageM, $ageAtMarriageF);

$duration  = $statistic->getMarriageDurationDistribution();
$ageGap    = $statistic->getCoupleAgeGapDistribution();
$byCentury = $statistic->getWeddingsByCentury();
$byMonth   = $statistic->getWeddingsByMonth();

$divorcesByCentury = $statistic->getDivorcesByCentury();
$divorcesByMonth   = $statistic->getDivorcesByMonth();
$divorceAgeM       = $statistic->getAgeAtDivorceDistribution('M');
$divorceAgeF       = $statistic->getAgeAtDivorceDistribution('F');

// Same co-zero trim for the divorce-age histograms.
[$divorceAgeM, $divorceAgeF] = HistogramTrim::dropCoZeroEnds($divorceAgeM, $divorceAgeF);
$cohortRates                 = $statistic->getDivorceRateByMarriageCohort();

$avgChildren        = $statistic->getAverageChildrenPerFamily();
$childrenHistogram  = $statistic->getChildrenPerFamilyHistogram();
$siblingGaps        = $statistic->getSiblingAgeGapDistribution();
$largestFamilies    = $statistic->getTopLargestFamilies(10);
$childlessBreakdown = $statistic->getChildlessFamiliesBreakdown();
$firstChildMonth    = $statistic->getFirstChildrenByMonth();

$totalChildrenFamilies = array_sum($childrenHistogram);
$totalSiblingPairs     = array_sum($siblingGaps);
$totalFirstChildMonth  = array_sum($firstChildMonth);

$ancestorDistribution = $statistic->getAncestorCountDistribution();
$avgPedigree          = $statistic->getAveragePedigreeCompleteness();
$totalAncestorsRows   = array_sum($ancestorDistribution);

$generationDepth             = $statistic->getGenerationDepthSummary();
$generationDepthDistribution = [];

foreach ($generationDepth['distribution'] as $gen => $count) {
    $generationDepthDistribution[(string) $gen] = $count;
}

$ageAtFirstChildM = $statistic->getAgeAtFirstChildDistribution('M');
$ageAtFirstChildF = $statistic->getAgeAtFirstChildDistribution('F');
$endogamy         = $statistic->getEndogamySummary();

// Trim co-zero ends so the side-by-side fathers/mothers histograms
// don't begin and end with rows of 0/0 that carry no information.
[$ageAtFirstChildM, $ageAtFirstChildF] = HistogramTrim::dropCoZeroEnds($ageAtFirstChildM, $ageAtFirstChildF);

$totalFirstChildM = array_sum($ageAtFirstChildM);
$totalFirstChildF = array_sum($ageAtFirstChildF);

$pedigreeExplanation = I18N::translate(
    'Each person in the tree has up to 30 possible direct ancestors within four generations (2 parents + 4 grandparents + 8 great-grandparents + 16 great-great-grandparents). The pedigree-completeness index (Lacy 1989) is the fraction of those 30 slots that are actually documented for that individual. The number shown here is the average across every individual in the tree, so 12 percent means "on average each person has 12 percent of their 4-generation ancestry recorded". Higher = more thorough research; lower = many gaps. Caveats: pedigree-collapse duplicates (cousin marriages) are not deduplicated, recent leaf-imports without ancestors drag the average down, and only direct ancestors are counted — siblings / cousins are out of scope.'
);

// Cohort-rate is a fraction — multiply by 100 to read as a percentage
// and drop empty cohorts so the bar list isn't all zeros on trees
// with very few divorces.
$cohortRatePercent = [];

foreach ($cohortRates as $cohort => $rate) {
    $cohortRatePercent[$cohort] = (int) round($rate * 100);
}

$totalAgeM    = array_sum($ageAtMarriageM);
$totalAgeF    = array_sum($ageAtMarriageF);
$totalDur     = array_sum($duration);
$totalAgeGap  = array_sum($ageGap);
$totalCentury = array_sum($byCentury);
$totalMonth   = array_sum($byMonth);

$totalDivCentury = array_sum($divorcesByCentury);
$totalDivMonth   = array_sum($divorcesByMonth);
$totalDivAgeM    = array_sum($divorceAgeM);
$totalDivAgeF    = array_sum($divorceAgeF);
?>
<div class="container">

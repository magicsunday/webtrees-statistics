    $weddingsByCenturyBars[] = [
        'label'        => (string) $century,
        'value'        => (int) $count,
        'tooltipLabel' => CenturyName::longLabel((string) $century),
        'tooltip'      => I18N::plural('%s marriage', '%s marriages', (int) $count, I18N::number($count)),
    ];
}

// Pre-built MirrorHistogram rows — tooltipLabel + tooltipBody go
// through literal `I18N::translate` / `I18N::plural` calls so
// xgettext picks the strings up. Helper-closures here would put
// the literal pair behind a variable and break extraction.
$ageAtMarriageMRows = [];

foreach ($ageAtMarriageM as $band => $count) {
    $bandCount            = (int) $count;
    $ageAtMarriageMRows[] = [
        'label'        => (string) $band,
        'value'        => $bandCount,

        'value'        => $bandCount,
        'tooltipLabel' => I18N::translate('%s years', (string) $band),
        'tooltipBody'  => I18N::plural('%s wife', '%s wives', $bandCount, I18N::number($bandCount)),
    ];
}

$ageAtFirstChildMRows = [];

foreach ($ageAtFirstChildM as $band => $count) {

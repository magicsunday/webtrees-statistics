declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$birthsByCountry     = $statistic->getBirthsByCountry();
$residencesByCountry = $statistic->getResidencesByCountry();
$deathsByCountry     = $statistic->getDeathsByCountry();
$migrationFlows      = $statistic->getMigrationFlows(20);
$placeDispersion     = $statistic->getPlaceDispersionSummary();

$totalBirths     = array_sum(array_column($birthsByCountry, 'count'));
$totalResidences = array_sum(array_column($residencesByCountry, 'count'));
$totalDeaths     = array_sum(array_column($deathsByCountry, 'count'));

$birthsList     = [];
$residencesList = [];
$deathsList     = [];

foreach ($birthsByCountry as $values) {
    $birthsList[$values['label']] = $values['count'];
}

foreach ($residencesByCountry as $values) {
    $residencesList[$values['label']] = $values['count'];
}

foreach ($deathsByCountry as $values) {
    $deathsList[$values['label']] = $values['count'];
}

$sankeyExplanation = I18N::translate(
    'Each flow shows individuals who were born in one country and died in another. The flow\'s thickness encodes the count: thicker bands mean more migrations along that path. Same-country trajectories are excluded — they\'re not migration. Hover any band to see the exact source → destination and individual count.'
);

$placeDispersionExplanation = I18N::translate(
    'For every individual the widget collects every distinct PLAC value that appears on any of their level-1 events (BIRT, DEAT, BAPM, BURI, RESI, …) and counts the unique places. Duplicates within the same individual (e.g. BIRT and DEAT both in Hamburg) collapse to one place, so the count reflects geographic mobility rather than how many events are recorded. The average is across every individual with at least one PLAC sample; individuals with no place data at all are excluded. The distribution on the right shows how those counts split across 1 / 2 / 3 / 4 / 5+ distinct places per person — a high tail signals migrant ancestors, a heavy bar at "1" signals a sedentary or sparsely-documented population.'
);

// Interpret the average distinct-places-per-individual into a
// one-line characterisation of the population — sedentary,
// moderately mobile, or strongly mobile. Thresholds picked from
// observation of real genealogical datasets: below 1.5 ≈ village
// communities where most individuals never moved; 1.5-2.5 ≈ rural
// populations with regional migration; 2.5-4 ≈ urbanised cohorts;
// above 4 ≈ migrant ancestors (settlers, emigrants, traders).
$dispersionInterpretation = match (true) {
    $placeDispersion->average < 1.5  => I18N::translate('A sedentary population — most lived and died in the same place.'),
    $placeDispersion->average < 2.5  => I18N::translate('Moderate mobility — many stayed in their region, some moved.'),
    $placeDispersion->average < 4.0  => I18N::translate('Mobile population — migration and relocation were common.'),
    default                           => I18N::translate('High mobility — strongly migrating ancestors.'),
};

// BarChart rows for the distinct-places-per-individual histogram —
// matches design2 `Histogram rows={D.placesPerPerson}`. tooltipLabel
// + tooltip use literal I18N calls so xgettext picks them up.
$placeDispersionBars = [];

foreach ($placeDispersion->distribution as $bucket => $count) {
    $bucketCount           = (int) $count;
    $placeDispersionBars[] = [
        'label'        => (string) $bucket,
        'value'        => $bucketCount,
        'tooltipLabel' => I18N::translate('%s distinct places', (string) $bucket),
        'tooltip'      => I18N::plural('%s individual', '%s individuals', $bucketCount, I18N::number($bucketCount)),
    ];
}

$placesPanel = static function (string $title, string $progressClass, string $mapIdentifier, array $list, array $rawData) use ($module): string {
    $progress = view($module . '::modules/statistics-chart/Partials/ProgressList', [
        'class' => $progressClass,
        'data'  => array_slice($list, 0, 10),
    ]);
    $map = view($module . '::modules/statistics-chart/Partials/GeoMap', [
        'identifier' => $mapIdentifier,
        'class'      => '',
        'data'       => $rawData,
    ]);

    return '<div class="row"><div class="col-md-3">' . $progress . '</div>'
        . '<div class="col-md-9 mt-3 mt-md-0">' . $map . '</div></div>';
};
?>
<div class="wt-stat-grid">

    <?php echo view($module . '::modules/statistics-chart/Partials/Section', [
        'kicker' => I18N::translate('Origin & fate'),
        'title'  => I18N::translate('Where they lived and died'),
        'sub'    => I18N::translate('Births, residences and deaths by country — the geographic spread of the tree'),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Geographic origin & fate'),
        'sub'          => I18N::translate('Three views of every individual — birth, residence, death'),
        'eyebrow'      => I18N::translate('Geography'),
        'accent'       => 'var(--slate)',
        'illustration' => 'globe',
        'span'         => 12,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/PlacesPanel', [
            'module' => $module,
            'views'  => [
                [
                    'view'          => 'birth',
                    'label'         => I18N::translate('Places of birth'),
                    'accent'        => 'var(--sage)',
                    'total'         => $totalBirths,
                    'list'          => $birthsList,
                    'raw'           => $birthsByCountry,
                    'progressClass' => 'progress-births-country',
                    'mapIdentifier' => 'living-geo-map',
                ],
                [
                    'view'          => 'residence',
                    'label'         => I18N::translate('Recorded residences'),
                    'accent'        => 'var(--slate)',
                    'total'         => $totalResidences,
                    'list'          => $residencesList,
                    'raw'           => $residencesByCountry,
                    'progressClass' => 'progress-residences-country',
                    'mapIdentifier' => 'residences-geo-map',
                ],
                [
                    'view'          => 'death',
                    'label'         => I18N::translate('Places of death'),
                    'accent'        => 'var(--wine)',
                    'total'         => $totalDeaths,
                    'list'          => $deathsList,
                    'raw'           => $deathsByCountry,
                    'progressClass' => 'progress-deaths-country',
                    'mapIdentifier' => 'deaths-geo-map',
                ],
            ],
        ]),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Section', [
        'kicker' => I18N::translate('Migration'),
        'title'  => I18N::translate('Movements'),
        'sub'    => I18N::translate('Individuals born in one country and recorded as having died in another'),
    ]); ?>

    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Migrations between birth and death country'),
        'sub'          => I18N::translate('Paths of individuals born in one country and recorded as having died in another'),
        'eyebrow'      => I18N::translate('Movement'),
        'accent'       => 'var(--wine)',
        'illustration' => 'boat',
        'info'         => $sankeyExplanation,
        'span'         => 12,
        'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/SankeyFlow', ['identifier' => 'migration-sankey', 'data' => $migrationFlows]),
    ]); ?>

    <?php if ($placeDispersion->sampled > 0) { ?>
        <?php echo view($module . '::modules/statistics-chart/Partials/Section', [
            'kicker' => I18N::translate('Mobility'),
            'title'  => I18N::translate('How far they roamed'),
            'sub'    => I18N::translate('Number of distinct places per individual — sedentary vs. migrating populations'),
        ]); ?>

        <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
            'module'       => $module,
            'title'        => I18N::translate('Geographic dispersion'),
            'sub'          => I18N::translate('Average distinct places per individual'),
            'eyebrow'      => I18N::translate('Mobility'),
            'accent'       => 'var(--sage)',
            'illustration' => 'globe',
            'info'         => $placeDispersionExplanation,
            'span'         => 5,
            'centered'     => true,
            'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/Scalar', [
                'value'   => I18N::number($placeDispersion->average, 2),
                'unit'    => I18N::translate('places'),
                'caption' => I18N::plural(
                    'Across %s individual with at least one recorded place.',
                    'Across %s individuals with at least one recorded place.',
                    $placeDispersion->sampled,
                    I18N::number($placeDispersion->sampled),
                ) . ' ' . $dispersionInterpretation,
            ]),
        ]); ?>

        <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
            'module'       => $module,
            'title'        => I18N::translate('Distinct places per individual'),
            'sub'          => I18N::translate('Distribution in buckets'),
            'eyebrow'      => I18N::translate('Mobility'),
            'accent'       => 'var(--slate)',
            'illustration' => 'globe',
            'span'         => 7,
            'bodyHtml'     => view($module . '::modules/statistics-chart/Partials/BarChart', [
                'identifier' => 'place-dispersion-bars',
                'data'       => $placeDispersionBars,
                'ariaLabel'  => I18N::translate('Distinct places per individual'),
            ]),
        ]); ?>
    <?php } ?>

</div>

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$migrationFlows = $statistic->getMigrationFlows(20);

$sankeyExplanation = I18N::translate(
    'Each flow shows individuals who were born in one country and died in another. The flow\'s thickness encodes the count: thicker bands mean more migrations along that path. Same-country trajectories are excluded — they\'re not migration. Hover any band to see the exact source → destination and individual count.'
);
?>
<div class="container">
    <div class="row row-cols-1 row-cols-md-1 g-3">
        <div class="col" data-map-type="birth">
            <div class="card h-100">
                <?php
                    $birthsByCountry = $statistic->getBirthsByCountry();
$totalBirths                         = array_sum(array_column($birthsByCountry, 'count'));
?>
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Place of birth'); ?></h5>
                    <small><?php echo I18N::plural('%s recorded country of birth', '%s recorded countries of birth', $totalBirths, I18N::number($totalBirths)); ?></small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <?php
                $progressList = [];

foreach ($birthsByCountry as $values) {
    $progressList[$values['label']] = $values['count'];
}

echo view(
    $module . '::modules/statistics-chart/Partials/ProgressList',
    [
        'class' => 'progress-births-country',
        'data'  => array_slice($progressList, 0, 10),
    ]
);
?>
                        </div>
                        <div class="col-md-9 mt-3 mt-md-0">
                            <?php
    echo view(
        $module . '::modules/statistics-chart/Partials/GeoMap',
        [
            'identifier' => 'living-geo-map',
            'class'      => '',
            'data'       => $birthsByCountry,
        ]
    );
?>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col" data-map-type="death">
            <div class="card h-100">
                <?php
                    $deathsByCountry = $statistic->getDeathsByCountry();
$totalDeaths                         = array_sum(array_column($deathsByCountry, 'count'));
?>
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Place of death'); ?></h5>
                    <small><?php echo I18N::plural('%s recorded country of death', '%s recorded countries of death', $totalDeaths, I18N::number($totalDeaths)); ?></small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <?php
                $progressList = [];

foreach ($deathsByCountry as $values) {
    $progressList[$values['label']] = $values['count'];
}

echo view(
    $module . '::modules/statistics-chart/Partials/ProgressList',
    [
        'class' => 'progress-deaths-country',
        'data'  => array_slice($progressList, 0, 10),
    ]
);
?>
                        </div>
                        <div class="col-md-9 mt-3 mt-md-0">
                            <?php
    echo view(
        $module . '::modules/statistics-chart/Partials/GeoMap',
        [
            'identifier' => 'deaths-geo-map',
            'class'      => '',
            'data'       => $deathsByCountry,
        ]
    );
?>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title">
                        <?php echo I18N::translate('Migrations between birth and death country'); ?>
                        <button
                            type="button"
                            class="wt-card-info-button"
                            data-bs-toggle="popover"
                            data-bs-trigger="hover focus"
                            data-bs-placement="top"
                            data-bs-html="false"
                            data-bs-title="<?php echo e(I18N::translate('About this chart')); ?>"
                            data-bs-content="<?php echo e($sankeyExplanation); ?>"
                            aria-label="<?php echo e(I18N::translate('About this chart')); ?>"
                        >?</button>
                    </h5>
                    <small><?php echo I18N::plural('%s distinct migration path', '%s distinct migration paths', count($migrationFlows['links']), I18N::number(count($migrationFlows['links']))); ?></small>
                </div>
                <div class="card-body">
                    <?php
        echo view(
            $module . '::modules/statistics-chart/Partials/SankeyFlow',
            [
                'identifier' => 'migration-sankey',
                'data'       => $migrationFlows,
            ]
        );
?>
                </div>
            </div>
        </div>
    </div>
</div>

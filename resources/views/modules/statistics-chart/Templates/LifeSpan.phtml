    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module'       => $module,
        'title'        => I18N::translate('Winter-peak score'),
        'sub'          => I18N::translate('Dec – Feb vs. baseline'),
        'eyebrow'      => I18N::translate('Season'),
        'accent'       => 'var(--wine)',
        'illustration' => 'moon',
        'span'         => 4,
        'centered'     => true,
        'bodyRenderer' => static function () use ($module, $winterPeakScore): void {
            if ($winterPeakScore !== null) {
                $deviation = ($winterPeakScore->score - 1.0) * 100.0;

                if ($deviation > 0.5) {
                    $caption = I18N::translate(
                        'Winter months show a %s%% higher mortality density than the annual average.',
                        I18N::number(abs($deviation), 0),
                    );
                } elseif ($deviation < -0.5) {
                    $caption = I18N::translate(
                        'Winter months show a %s%% lower mortality density than the annual average.',
                        I18N::number(abs($deviation), 0),
                    );
                } else {
                    $caption = I18N::translate('Deaths are evenly spread across the year.');
                }

                // Multiplier sigil stays inline with the serif value so
                // the "× 0,84" reads as a single ratio token; Scalar's
                // optional `unit` slot is reserved for trailing units
                // (e.g. years, %), not leading sigils.
                echo view($module . '::modules/statistics-chart/Partials/Scalar', [
                    'value'   => '× ' . I18N::number($winterPeakScore->score, 2),
                    'unit'    => null,
                    'caption' => $caption,
                ]);
            } else {
                echo EmptyStatePlaceholder::render();
            }
        },
    ]); ?>


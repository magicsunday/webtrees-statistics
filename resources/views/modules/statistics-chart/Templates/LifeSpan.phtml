use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Model\Dto\LineChart\LineChartPayload;
use MagicSunday\Webtrees\Statistic\Statistic;
use MagicSunday\Webtrees\Statistic\Support\CenturyName;
use MagicSunday\Webtrees\Statistic\Support\EmptyStatePlaceholder;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$birthsByMonth      = $statistic->getBirthsByMonth();
$birthsByZodiacSign = $statistic->getBirthsByZodiacSign();
$birthsByCentury    = $statistic->getBirthsByCentury();
$birthsByDecade     = $statistic->getBirthsByDecade();
$deathsByMonth      = $statistic->getDeathsByMonth();
$deathsByCentury    = $statistic->getDeathsByCentury();

$ageAtDeath              = $statistic->getAgeAtDeathDistribution();
$topOldestDeceased       = $statistic->getTopOldestDeceased(10);
$topOldestLiving         = $statistic->getTopOldestLiving(10);
$livingByAgeBand         = $statistic->getLivingByAgeBand();
$topDeathCauses          = $statistic->getTopDeathCauses(15);
$totalDeathCauses        = $statistic->getTotalDeathCauses();
$winterPeakScore         = $statistic->getDeathWinterPeakScore();
$childMortality          = $statistic->getChildMortalitySummary();
$childMortalityByCentury = $statistic->getChildMortalityByBirthCentury();
$lifespanBySexCentury    = $statistic->getAverageLifespanBySexAndCentury();

$totalBirthsByMonth   = array_sum($birthsByMonth);
$totalBirthsByZodiac  = array_sum($birthsByZodiacSign);
$totalBirthsByCentury = array_sum($birthsByCentury);
$totalBirthsByDecade  = array_sum($birthsByDecade);
$totalDeathsByMonth   = array_sum($deathsByMonth);
$totalDeathsByCentury = array_sum($deathsByCentury);
$totalAgeAtDeath      = array_sum($ageAtDeath);
$totalLivingBanded    = array_sum(array_column($livingByAgeBand, 'value'));

// Enrich the living-age-band slices with long-form tooltip text
// (band-in-years header + plural-aware "N persons" body). The donut
// widget falls back to label/value when tooltipLabel/tooltipBody
// are missing, so the enrichment is local to this template.
$livingByAgeBand = array_map(
    static function (array $band): array {
        $value = $band['value'];

        return $band + [
            'tooltipLabel' => I18N::translate('%s years', $band['label']),
            'tooltipBody'  => I18N::plural('%s person', '%s persons', $value, I18N::number($value)),
        ];
    },
    $livingByAgeBand,
);

$birthsByDecadePayload = LineChartPayload::singleSeries(
    seriesName: I18N::translate('Births'),
    countsByCategory: $birthsByDecade,
    project: static fn (int|string $decade, int|float $count): array => [
        'categoryLabel' => I18N::translate('%ss', (string) $decade),
        'tooltipBody'   => I18N::plural('%s birth', '%s births', (int) $count, I18N::number($count)),
        'tooltipLabel'  => I18N::translate('%ss', (string) $decade),
    ],
);

$birthsByDecadeXLabelEvery = max(1, (int) ceil(count($birthsByDecadePayload->categories) / 12));

$mortalityByCentury = [];
$mortalityTooltips  = [];

foreach ($childMortalityByCentury as $entry) {
    $century                      = (int) $entry['century'];
    $mortalityByCentury[$century] = (float) $entry['rate'];
    $mortalityTooltips[$century]  = I18N::translate(
        '%1$s%% — %2$s of %3$s children died before age 5',
        I18N::number((float) $entry['rate'], 1),
        I18N::number((int) $entry['died']),
        I18N::number((int) $entry['total']),
    );
}

$childMortalityPayload = LineChartPayload::singleSeries(
    seriesName: I18N::translate('Mortality rate'),
    countsByCategory: $mortalityByCentury,
    project: static function (int|string $century, int|float $rate) use ($mortalityTooltips): array {
        $label = CenturyName::for((int) $century);

        return [
            // Append the locale-specific "Jh." abbreviation so the x-axis
            // reads "16. Jh." instead of just "16." (DE) / "16th cent."
            // instead of "16th" (EN), matching the mockup tick style.
            'categoryLabel' => I18N::translate('%s cent.', $label),
            'tooltipBody'   => $mortalityTooltips[$century] ?? '',
            'tooltipLabel'  => CenturyName::longLabel($label),
        ];
    },
);

$childMortalityExplanation = I18N::translate(
    'For every individual with both BIRT and DEAT julian-days the widget computes the number of days lived; a death within five years (1826 days) of birth counts as under-5 mortality. The tree-wide percentage is the share of such children across the whole tree, and the LineChart on the right groups them by their birth century so the historical decline becomes visible (typical 1700s value 30-40 percent, modern below 2 percent). Individuals with only BIRT or only DEAT are silently excluded — we cannot determine survival without both anchors, and including them would skew the rate. Per-century cohorts below 5 children are suppressed because a single dead child would spike the line by more than 10 percentage points.'
);

// Cohort with the highest under-5 mortality rate — feeds the
// adjacent "Peak value" Scalar card. Sorted descending by rate so
// the first entry is the worst century.
$childMortalityPeak = null;

foreach ($childMortalityByCentury as $entry) {
    if (($childMortalityPeak === null) || ((float) $entry['rate'] > (float) $childMortalityPeak['rate'])) {
        $childMortalityPeak = $entry;
    }
}

// Convert the band → count map into the row-of-objects shape that
// the chart-lib BarChart payload expects. Empty bands are kept —
// the chart renders a 1-px stub on the baseline so the tick still
// communicates "nobody in this band" instead of dropping silently.
$ageAtDeathBars = [];

foreach ($ageAtDeath as $bandLabel => $count) {
    $ageAtDeathBars[] = [
        'label'        => (string) $bandLabel,
        'value'        => (int) $count,
        'tooltipLabel' => I18N::translate('%s years', (string) $bandLabel),
        'tooltip'      => I18N::plural('%s person', '%s persons', (int) $count, I18N::number($count)),
    ];
}

// Births / deaths per century — bar chart payload mirrors the
// histogram look in the mockup (one bar per century, ordered
// chronologically, full century name as tooltip header).
$birthsByCenturyBars = [];

foreach ($birthsByCentury as $century => $count) {
    $birthsByCenturyBars[] = [
        'label'        => (string) $century,
        'value'        => (int) $count,
        'tooltipLabel' => CenturyName::longLabel((string) $century),
        'tooltip'      => I18N::plural('%s birth', '%s births', (int) $count, I18N::number($count)),
    ];
}

$deathsByCenturyBars = [];

foreach ($deathsByCentury as $century => $count) {
    $deathsByCenturyBars[] = [
        'label'        => (string) $century,
        'value'        => (int) $count,
        'tooltipLabel' => CenturyName::longLabel((string) $century),
        'tooltip'      => I18N::plural('%s death', '%s deaths', (int) $count, I18N::number($count)),
    ];
}

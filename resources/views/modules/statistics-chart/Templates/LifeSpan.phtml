use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Statistic;
use MagicSunday\Webtrees\Statistic\Support\CenturyName;

/**
 * @var string    $module    The name of the module
 * @var Statistic $statistic
 */
$birthsByMonth      = $statistic->getBirthsByMonth();
$birthsByZodiacSign = $statistic->getBirthsByZodiacSign();
$birthsByCentury    = $statistic->getBirthsByCentury();
$deathsByMonth      = $statistic->getDeathsByMonth();
$deathsByCentury    = $statistic->getDeathsByCentury();

$ageAtDeath              = $statistic->getAgeAtDeathDistribution();
$topOldestDeceased       = $statistic->getTopOldestDeceased(10);
$topOldestLiving         = $statistic->getTopOldestLiving(10);
$livingByAgeBand         = $statistic->getLivingByAgeBand();
$topDeathCauses          = $statistic->getTopDeathCauses(15);
$winterPeakScore         = $statistic->getDeathWinterPeakScore();
$childMortality          = $statistic->getChildMortalitySummary();
$childMortalityByCentury = $statistic->getChildMortalityByBirthCentury();

$totalBirthsByMonth   = array_sum($birthsByMonth);
$totalBirthsByZodiac  = array_sum($birthsByZodiacSign);
$totalBirthsByCentury = array_sum($birthsByCentury);
$totalDeathsByMonth   = array_sum($deathsByMonth);
$totalDeathsByCentury = array_sum($deathsByCentury);
$totalAgeAtDeath      = array_sum($ageAtDeath);
$totalLivingBanded    = array_sum(array_column($livingByAgeBand, 'value'));
?>
<?php
$birthsByCenturySeries = [];

foreach ($birthsByCentury as $century => $count) {
    $birthsByCenturySeries[] = [
        'label'        => $century,
        'tooltipLabel' => $century . ' ' . I18N::translate('Century'),
        'value'        => $count,
        'tooltip'      => I18N::plural('%s birth', '%s births', $count, I18N::number($count)),
    ];
}

$deathsByCenturySeries = [];

foreach ($deathsByCentury as $century => $count) {
    $deathsByCenturySeries[] = [
        'label'        => $century,
        'tooltipLabel' => $century . ' ' . I18N::translate('Century'),
        'value'        => $count,
        'tooltip'      => I18N::plural('%s death', '%s deaths', $count, I18N::number($count)),
    ];
}

$childMortalitySeries = [];

foreach ($childMortalityByCentury as $entry) {
    $label = CenturyName::for($entry['century']);

    $childMortalitySeries[] = [
        'label'        => $label,
        'tooltipLabel' => $label . ' ' . I18N::translate('Century'),
        'value'        => $entry['rate'],
        'tooltip'      => I18N::translate(
            '%1$s%% — %2$s of %3$s children died before age 5',
            I18N::number($entry['rate'], 1),
            I18N::number($entry['died']),
            I18N::number($entry['total']),
        ),
    ];
}
?>
<div class="container">
    <div class="row row-cols-1 row-cols-md-2 g-3">
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Births by month'); ?></h5>
                    <small><?php echo I18N::plural('%s individual with a recorded birth month', '%s individuals with a recorded birth month', $totalBirthsByMonth, I18N::number($totalBirthsByMonth)); ?></small>
                </div>
                <div class="card-body">
                    <?php
                        echo view(
                            $module . '::modules/statistics-chart/Partials/ProgressList',
                            [
                                'class' => 'progress-births-month',
                                'data'  => $birthsByMonth,
                            ],
                        );
?>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Births by zodiac sign'); ?></h5>
                    <small><?php echo I18N::plural('%s individual with a known zodiac sign', '%s individuals with a known zodiac sign', $totalBirthsByZodiac, I18N::number($totalBirthsByZodiac)); ?></small>
                </div>
                <div class="card-body">
                    <?php
    echo view(
        $module . '::modules/statistics-chart/Partials/ProgressList',
        [
            'class' => 'progress-births-zodiac',
            'data'  => $birthsByZodiacSign,
        ],
    );
?>
                </div>
            </div>
        </div>
    </div>

    <?php if ($birthsByCenturySeries !== []) { ?>
    <div class="row g-3 mt-1 mb-3">
        <div class="col">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Births by century'); ?></h5>
                    <small><?php echo I18N::plural('%s individual with a recorded birth year', '%s individuals with a recorded birth year', $totalBirthsByCentury, I18N::number($totalBirthsByCentury)); ?></small>
                </div>
                <div class="card-body">
                    <?php
        echo view(
            $module . '::modules/statistics-chart/Partials/LineChart',
            [
                'identifier' => 'births-century-line',
                'data'       => $birthsByCenturySeries,
            ],
        );
        ?>
                </div>
            </div>
        </div>
    </div>
    <?php } ?>

    <div class="row row-cols-1 row-cols-md-2 g-3 mt-1 mb-3">
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Deaths by month'); ?></h5>
                    <small><?php echo I18N::plural('%s individual with a recorded death month', '%s individuals with a recorded death month', $totalDeathsByMonth, I18N::number($totalDeathsByMonth)); ?></small>
                </div>
                <div class="card-body">
                    <?php
            echo view(
                $module . '::modules/statistics-chart/Partials/ProgressList',
                [
                    'class' => 'progress-deaths-month',
                    'data'  => $deathsByMonth,
                ],
            );
?>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Winter-peak score'); ?></h5>
                    <small><?php echo I18N::translate('Relative density of deaths in December – February compared with an even 12-month baseline.'); ?></small>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <?php
            if ($winterPeakScore !== null) {
                $scoreCaption = I18N::translate('%1$s of %2$s deaths fell in December – February. 1.0 = no seasonality, > 1.0 = winter-peaked, < 1.0 = winter-trough.', I18N::number($winterPeakScore['seasonCount']), I18N::number($winterPeakScore['total']));
                echo view(
                    $module . '::modules/statistics-chart/Partials/Scalar',
                    [
                        'value'   => I18N::number($winterPeakScore['score'], 2),
                        'unit'    => '×',
                        'caption' => $scoreCaption,
                    ],
                );
            } else {
                echo view(
                    $module . '::modules/statistics-chart/Partials/Scalar',
                    [
                        'value'   => I18N::translate('no data'),
                        'unit'    => null,
                        'caption' => I18N::translate('At least 12 dated deaths are required for a meaningful score.'),
                    ],
                );
            }
?>
                </div>
            </div>
        </div>
    </div>

    <?php if ($deathsByCenturySeries !== []) { ?>
    <div class="row g-3 mt-1 mb-3">
        <div class="col">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title"><?php echo I18N::translate('Deaths by century'); ?></h5>

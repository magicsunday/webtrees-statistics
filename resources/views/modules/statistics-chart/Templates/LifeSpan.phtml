    <?php echo view($module . '::modules/statistics-chart/Partials/Card', [
        'module' => $module,
        'title'  => I18N::translate('Peak value'),
        'sub'    => $childMortalityPeak !== null
            ? I18N::translate('Child mortality %s century', CenturyName::for((int) $childMortalityPeak['century']))
            : null,
        'eyebrow'      => I18N::translate('Extreme'),
        'accent'       => 'var(--wine)',
        'illustration' => 'candle',
        'span'         => 4,
        'centered'     => true,
        'bodyRenderer' => static function () use ($module, $childMortalityPeak): void {
            if ($childMortalityPeak === null) {
                echo EmptyStatePlaceholder::render();

                return;
            }

            echo view($module . '::modules/statistics-chart/Partials/Scalar', [
                'value'   => I18N::number((float) $childMortalityPeak['rate'], 1),

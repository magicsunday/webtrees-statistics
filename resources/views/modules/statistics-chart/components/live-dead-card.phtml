declare(strict_types=1);

use Fisharebest\Webtrees\I18N;

/**
 * Living vs deceased card body — two big serif counts framing a
 * thin stack-bar segment, mirroring the mockup's `.gs-livedead`
 * layout. The numbers carry the sage / mute accents so the
 * proportion is readable at a glance.
 *
 * @var int $living   Number of living individuals
 * @var int $deceased Number of deceased individuals
 */
$total       = $living + $deceased;
$livingPct   = ($total > 0) ? ($living / $total) * 100 : 0;
$deceasedPct = ($total > 0) ? ($deceased / $total) * 100 : 0;
?>
<div class="wt-stat-livedead">
    <div class="wt-stat-livedead-row">
        <span class="wt-stat-livedead-num wt-stat-serif" style="color: var(--sage);"><?php echo e(I18N::number($living)); ?></span>
        <span class="wt-stat-livedead-lab"><?php echo e(I18N::translate('living today')); ?></span>
    </div>
    <div class="wt-stat-stackbar" role="img" aria-label="<?php echo e(I18N::translate('Living vs deceased proportion')); ?>">
        <span class="wt-stat-stackbar-seg" style="flex: <?php echo (int) round($livingPct * 100); ?>; background: var(--sage);"></span>
        <span class="wt-stat-stackbar-seg" style="flex: <?php echo (int) round($deceasedPct * 100); ?>; background: var(--deceased);"></span>
    </div>
    <div class="wt-stat-livedead-row wt-stat-livedead-row-r">
        <span class="wt-stat-livedead-lab"><?php echo e(I18N::translate('deceased')); ?></span>
        <span class="wt-stat-livedead-num wt-stat-serif" style="color: var(--deceased);"><?php echo e(I18N::number($deceased)); ?></span>
    </div>
</div>

declare(strict_types=1);

use MagicSunday\Webtrees\Statistic\Support\WidgetJson;
use MagicSunday\Webtrees\Statistic\View\EmptyStatePlaceholder;

/**
 * @var string                                                                                            $identifier Host element id
 * @var array<int, array{label: string, value: int, sign: -1|1, tooltip?: string, tooltipLabel?: string}> $data       Rows in display order
 * @var string|null                                                                                       $ariaLabel  Accessible label on the host svg
 * @var string|null                                                                                       $leftCap    Caption rendered beneath the chart on the left side (negative-sign meaning)
 * @var string|null                                                                                       $rightCap   Caption rendered beneath the chart on the right side (positive-sign meaning)
 */
$leftCap  ??= null;
$rightCap ??= null;

if (($data === []) || (array_sum(array_map(static fn (array $row): int => abs($row['value']), $data)) <= 0)) {
    echo EmptyStatePlaceholder::render();

    return;
}
?>
<div class="wt-diverging-bar-container">
    <div id="<?php echo e($identifier); ?>"
         class="wt-diverging-bar-host"
         data-widget="diverging-bar"
         data-payload="<?php echo WidgetJson::encodeAttribute($data); ?>"
         data-options="<?php echo WidgetJson::encodeAttribute([
             'ariaLabel' => $ariaLabel ?? null,
         ]); ?>"
         data-empty-message="<?php echo e(EmptyStatePlaceholder::defaultMessage()); ?>"
    ></div>
    <?php if ((($leftCap !== null) && ($leftCap !== '')) || (($rightCap !== null) && ($rightCap !== ''))) { ?>
        <div class="wt-stat-diverging-cap" aria-hidden="true">
            <span class="wt-stat-diverging-cap-left"><?php echo '&larr; ' . e((string) $leftCap); ?></span>
            <span class="wt-stat-diverging-cap-right"><?php echo e((string) $rightCap) . ' &rarr;'; ?></span>
        </div>
    <?php } ?>
</div>

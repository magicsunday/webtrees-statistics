declare(strict_types=1);

use MagicSunday\Webtrees\Statistic\Model\Pyramid\PopulationPyramidPayload;
use MagicSunday\Webtrees\Statistic\Support\WidgetJson;
use MagicSunday\Webtrees\Statistic\View\EmptyStatePlaceholder;

/**
 * Population-pyramid widget shell. Emits a `data-widget="population-pyramid"`
 * marker carrying the `{groups, bands, data}` payload for the domain-neutral
 * chart-lib pyramid widget. Bar and picker colours come from CSS
 * (`.wt-diverging-bar-left`, `-bar-right`, `.wt-diverging-group`) — not
 * from PHP options. The group (century) labels in the payload are already
 * localised, so the widget renders them verbatim. The left/right captions (here
 * male/female) and the centre axis title are passed in pre-translated by the
 * caller so xgettext extracts them at the tab call-site rather than inside this
 * shared partial.
 *
 * @var string                   $identifier Host element id
 * @var PopulationPyramidPayload $data       Group × band × {left, right} payload
 * @var int|null                 $height     Optional viewport height (defaults to 460)
 * @var string|null              $ariaLabel  Accessible label on the host svg
 * @var string|null              $leftLabel    Pre-translated caption for the left column
 * @var string|null              $rightLabel   Pre-translated caption for the right column
 * @var string|null              $axisLabel    Pre-translated centre gutter title
 * @var string|null              $categoryUnit Pre-translated unit appended to the band in the tooltip
 * @var string|null              $valueLabel   Pre-translated unit appended to the count in the tooltip
 * @var string|null              $ease         Entrance/switch easing name (e.g. "cubic-out", "back-out")
 * @var string|null              $source       Crossfilter source id for the shared selection bus
 */
$height ??= 460;

if ($data->groups === []) {
    echo EmptyStatePlaceholder::render();

    return;
}

$options = [
    'height'       => $height,
    'ariaLabel'    => $ariaLabel ?? null,
    'leftLabel'    => $leftLabel ?? null,
    'rightLabel'   => $rightLabel ?? null,
    'axisLabel'    => $axisLabel ?? null,
    'categoryUnit' => $categoryUnit ?? null,
    'valueLabel'   => $valueLabel ?? null,
    'ease'         => $ease ?? null,
];

if (isset($source) && ($source !== '')) {
    $options['source'] = $source;
}
?>
<div class="wt-diverging-host"
     id="<?php echo e($identifier); ?>"
     data-widget="population-pyramid"
     data-payload="<?php echo WidgetJson::encodeAttribute($data); ?>"
     data-options="<?php echo WidgetJson::encodeAttribute($options); ?>"
     data-empty-message="<?php echo e(EmptyStatePlaceholder::defaultMessage()); ?>"></div>

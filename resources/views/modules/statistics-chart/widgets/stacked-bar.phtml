declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Model\StackedBar\StackedBarPayload;
use MagicSunday\Webtrees\Statistic\Support\WidgetJson;
use MagicSunday\Webtrees\Statistic\View\EmptyStatePlaceholder;

/**
 * @var string            $identifier Host element id
 * @var StackedBarPayload $data       Stacked-bar payload: categories + per-series counts
 * @var int|null          $height     Optional viewport height (defaults to 280)
 * @var bool|null         $legend     Toggle the legend row (default true)
 * @var bool|null         $percentage Toggle 100%-stacked composition view (default false)
 * @var string|null       $ariaLabel  Accessible label on the host svg
 */
$height ??= 280;

// Treat an empty / all-zero payload as no data — categories empty,
// or every value in every series is zero. Avoids rendering an axis
// with twelve invisible stacks on a tree where the metric never
// fired.
$seriesEmpty = static function () use ($data): bool {
    foreach ($data->series as $series) {
        foreach ($series->data as $value) {
            if ($value > 0) {
                return false;
            }
        }
    }

    return true;
};

if (($data->categories === []) || $seriesEmpty()) {
    echo EmptyStatePlaceholder::render();

    return;
}

// chart-lib stacked-bar reads `options.i18n.totalInCategoryPattern`
// to localise the tooltip's per-category footer. Curly-brace {count}
// placeholder instead of sprintf %s — see the StreamGraph partial
// for the rationale.
$stackedBarI18n = [
    'totalInCategoryPattern' => I18N::translate('{count} total in this category'),
];
?>
<div id="<?php echo e($identifier); ?>"
     class="wt-stat-stacked-bar-container"
     data-widget="stacked-bar"
     data-payload="<?php echo WidgetJson::encodeAttribute($data); ?>"
     data-options="<?php echo WidgetJson::encodeAttribute([
         'height'     => $height,
         'legend'     => $legend ?? null,
         'percentage' => $percentage ?? null,
         'ariaLabel'  => $ariaLabel ?? null,
         'i18n'       => $stackedBarI18n,
     ]); ?>"
     data-empty-message="<?php echo e(EmptyStatePlaceholder::defaultMessage()); ?>"
></div>

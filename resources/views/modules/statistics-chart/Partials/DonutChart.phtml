declare(strict_types=1);

use Fisharebest\Webtrees\I18N;

/**
 * @var string $identifier
 * @var array  $data
 */
?>

<div id="<?= $identifier ?>"></div>

<table class="legend">
    <?php foreach ($data as $entry): ?>
        <tr>
            <td>
                <span class="dot<?= isset($entry['class']) ? (' ' . $entry['class']) : '' ?>"
                    <?= isset($entry['fill']) ? (' style="background-color: ' . $entry['fill'] . ';"') : '' ?>
                ></span>
            </td>
            <td><?= $entry['label'] ?></td>
            <td><?= I18N::number($entry['value']) ?></td>
        </tr>
    <?php endforeach; ?>
</table>

<script>

document.getElementById(<?= json_encode($identifier, JSON_THROW_ON_ERROR) ?>)
    .append(
        webtreesStatistics.drawDonutChart(
            <?= json_encode($data, JSON_THROW_ON_ERROR) ?>
        )
    );

</script>


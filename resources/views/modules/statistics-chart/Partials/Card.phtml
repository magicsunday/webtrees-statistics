declare(strict_types=1);

use Fisharebest\Webtrees\I18N;

/**
 * Generic card frame for every widget on every tab. Owns the eyebrow
 * / title / sub header strip, the body slot, the optional accent
 * illustration anchored to the top-right corner, and the optional
 * info-popover footer button.
 *
 * The accent colour drives both the eyebrow label and the
 * illustration's `currentColor` stroke, so picking
 * `accent = 'var(--wine)'` paints the eyebrow `--wine` AND the
 * illustration `--wine` automatically.
 *
 * @var string        $module       Module slug for partial includes
 * @var string        $title        Card title (h3, serif)
 * @var string|null   $sub          Optional sub-heading below the title
 * @var string|null   $eyebrow      Optional kicker label above the title
 * @var int           $span         Grid column span (1–12). Default 12.
 * @var string|null   $accent       CSS color literal or var() reference, drives eyebrow + illustration
 * @var string|null   $illustration Illustration key (see Illustration.phtml). Renders into the top-right corner.
 * @var string|null   $info         Optional long-form help text. When set, the card grows an info button + popover.
 * @var bool          $centered     Centres the body content
 * @var bool          $showFooter   Render the dashed-line footer slot. Defaults to true ONLY when $info is set
 *                                  (i.e. when there's actually an info button to show). Cards without $info
 *                                  default to no footer so the dashed rhythm doesn't compete with the chart.
 *                                  Override either way per card if needed.
 * @var callable|null $bodyRenderer Optional callable that emits the body markup (echoed inside .wt-stat-card-body)
 * @var string        $bodyHtml     Optional pre-rendered HTML body (echoed verbatim — caller must e() any user content)
 */
$sub          ??= null;
$eyebrow      ??= null;
$span         ??= 12;
$accent       ??= null;
$illustration ??= null;
$info         ??= null;
$centered     ??= false;
$showFooter   ??= ($info !== null && $info !== '');
$bodyRenderer ??= null;
$bodyHtml     ??= '';

$classes = ['wt-stat-card'];

if ($illustration !== null) {
    $classes[] = 'wt-stat-card-illustrated';
}

if ($centered === true) {
    $classes[] = 'wt-stat-card-centered';
}

$style = 'grid-column: span ' . (int) $span . '; --wt-stat-card-span: ' . (int) $span . ';';

if ($accent !== null && $accent !== '') {
    $style .= ' --wt-stat-card-accent: ' . $accent . ';';
}
?>
<section class="<?php echo e(implode(' ', $classes)); ?>" style="<?php echo e($style); ?>">
    <?php if ($illustration !== null) { ?>
        <div class="wt-stat-card-illustration-clip" aria-hidden="true">
            <div class="wt-stat-card-illustration"
                 <?php if ($accent !== null) { ?>style="color: <?php echo e($accent); ?>;"<?php } ?>>
                <?php echo view($module . '::modules/statistics-chart/Partials/Illustration', ['name' => $illustration]); ?>
            </div>
        </div>
    <?php } ?>

    <header class="wt-stat-card-head">
        <?php if ($eyebrow !== null && $eyebrow !== '') { ?>
            <p class="wt-stat-card-eyebrow"
               <?php if ($accent !== null) { ?>style="color: <?php echo e($accent); ?>;"<?php } ?>>
                <?php echo e($eyebrow); ?>
            </p>
        <?php } ?>
        <h3 class="wt-stat-card-title"><?php echo e($title); ?></h3>
        <?php if ($sub !== null && $sub !== '') { ?>
            <p class="wt-stat-card-sub"><?php echo e($sub); ?></p>
        <?php } ?>
    </header>

    <div class="wt-stat-card-body">
        <?php
        if ($bodyRenderer !== null && is_callable($bodyRenderer)) {
            $bodyRenderer();
        } else {
            echo $bodyHtml;
        }
?>
    </div>

    <?php if ($showFooter === true) { ?>
        <footer class="wt-stat-card-foot">
            <?php if ($info !== null && $info !== '') { ?>
                <button type="button"
                        class="wt-stat-card-info"
                        data-bs-toggle="popover"
                        data-bs-trigger="focus hover"
                        data-bs-placement="top"
                        data-bs-html="true"
                        data-bs-custom-class="wt-stat-popover wt-popover-wide"
                        data-bs-title="<?php echo e(I18N::translate('About this chart')); ?>"
                        data-bs-content="<?php echo e($info); ?>"
                        aria-label="<?php echo e(I18N::translate('About this chart')); ?>">?</button>
            <?php } ?>
        </footer>
    <?php } ?>
</section>

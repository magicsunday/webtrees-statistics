use Fisharebest\Webtrees\I18N;

/**
 * @var string                                                                       $identifier Host element id
 * @var array{labels: list<string>, matrix: list<list<int>>, classes?: list<string>} $data    Chord payload — labels per arc + symmetric N×N connection matrix
 * @var int|null                                                                     $height     Optional viewport height (defaults to 360)
 * @var string|null                                                                  $ariaLabel  Accessible label on the host svg
 */
$height ??= 360;
?>
<div class="wt-chord-diagram-container">
    <div id="<?php echo e($identifier); ?>"
         class="wt-chord-diagram-host"
         data-widget="chord-diagram"
         data-payload="<?php echo e(json_encode($data, JSON_THROW_ON_ERROR | JSON_INVALID_UTF8_SUBSTITUTE)); ?>"
         data-options="<?php echo e(json_encode([
             'height'    => $height,
             'ariaLabel' => $ariaLabel ?? null,
         ], JSON_THROW_ON_ERROR | JSON_INVALID_UTF8_SUBSTITUTE)); ?>"
         data-empty-message="<?php echo e(I18N::translate('No data')); ?>"
    ></div>
</div>

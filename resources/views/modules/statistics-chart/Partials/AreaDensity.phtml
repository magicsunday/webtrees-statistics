use MagicSunday\Webtrees\Statistic\Support\EmptyStatePlaceholder;
use MagicSunday\Webtrees\Statistic\Support\WidgetJson;

/**
 * @var string                                                                                 $identifier Host element id
 * @var array<int, array{x: int|float, y: int|float, tooltip?: string, tooltipLabel?: string}> $data       Density rows
 * @var int|null                                                                               $height     Optional viewport height (defaults to 200)
 * @var bool|null                                                                              $showLine   Toggle the line stroke on top of the area (default true)
 * @var string|null                                                                            $ariaLabel  Accessible label on the host svg
 */
$height ??= 200;

if (($data === []) || (array_sum(array_column($data, 'y')) <= 0)) {
    echo EmptyStatePlaceholder::render();

    return;
}
?>
<div class="wt-area-density-container">
    <div id="<?php echo e($identifier); ?>"
         class="wt-area-density-host"
         data-widget="area-density"
         data-payload="<?php echo e(WidgetJson::encode($data)); ?>"
         data-options="<?php echo e(WidgetJson::encode([
             'height'    => $height,
             'showLine'  => $showLine ?? null,
             'ariaLabel' => $ariaLabel ?? null,
         ])); ?>"
         data-empty-message="<?php echo e(EmptyStatePlaceholder::defaultMessage()); ?>"
    ></div>
</div>

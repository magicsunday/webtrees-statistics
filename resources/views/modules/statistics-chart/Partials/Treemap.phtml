use Fisharebest\Webtrees\I18N;

/**
 * @var string $identifier Host element id
 * @var array{
 *     name: string,
 *     children: array<int, array{
 *         name: string,
 *         children?: array<int, array{name: string, value: int, class?: string}>,
 *         value?: int,
 *         class?: string
 *     }>
 * }                                                $data         Hierarchical treemap payload
 * @var int|null    $height     Optional viewport height (defaults to 320)
 * @var string|null $ariaLabel  Accessible label on the host svg
 */
$height ??= 320;
?>
<div class="wt-treemap-container">
    <div id="<?php echo e($identifier); ?>"
         class="wt-treemap-host"
         data-widget="treemap"
         data-payload="<?php echo e(json_encode($data, JSON_THROW_ON_ERROR | JSON_INVALID_UTF8_SUBSTITUTE)); ?>"
         data-options="<?php echo e(json_encode([
             'height'    => $height,
             'ariaLabel' => $ariaLabel ?? null,
         ], JSON_THROW_ON_ERROR | JSON_INVALID_UTF8_SUBSTITUTE)); ?>"
         data-empty-message="<?php echo e(I18N::translate('No data available yet.')); ?>"
    ></div>
</div>

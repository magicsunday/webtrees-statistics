use Fisharebest\Webtrees\I18N;

/**
 * Renders the recurring `?` info-trigger button that every chart and
 * metric card carries next to its title. The button toggles a
 * hover- and focus-activated Bootstrap popover whose body holds the
 * long-form context the card cannot fit into its `<small>` subtitle.
 * Centralising the trigger here keeps the popover behaviour (trigger
 * mode, placement, html-disabled body, aria-label / title parity)
 * pinned to one place across every consuming template.
 *
 * @var string      $content Long-form explanation rendered inside the popover (already plain text — the partial e()-wraps it)
 * @var string|null $kind    Card kind for the popover title — one of `chart`, `histogram`, `metric`; defaults to `chart`
 * @var bool|null   $wide    Toggle the `wt-popover-wide` modifier (default false — narrow popover)
 */
$kind ??= 'chart';
$wide ??= false;

$title = match ($kind) {
    'histogram' => I18N::translate('About this histogram'),
    'metric'    => I18N::translate('About this metric'),
    default     => I18N::translate('About this chart'),
};
?>
<button
    type="button"
    class="wt-card-info-button"
    data-bs-toggle="popover"
    data-bs-trigger="hover focus"
    data-bs-placement="top"
    data-bs-html="false"
    <?php if ($wide) { ?>data-bs-custom-class="wt-popover-wide"<?php } ?>
    data-bs-title="<?php echo e($title); ?>"
    data-bs-content="<?php echo e($content); ?>"
    aria-label="<?php echo e($title); ?>"
>?</button>

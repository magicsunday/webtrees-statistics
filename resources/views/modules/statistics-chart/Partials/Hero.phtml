declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Tree;
use MagicSunday\Webtrees\Statistic\Model\Dto\Tree\HeroStats;
use MagicSunday\Webtrees\Statistic\Support\SpelledNumber;

/**
 * @var Tree      $tree The current tree
 * @var HeroStats $hero Aggregated headline metrics
 */
$generations = $hero->maxGenerationDepth;
$avgGenYears = $hero->averageGenerationYears;
$deckText    = ($hero->centurySpan > 0)
    ? I18N::plural(
        'A statistical reading of one family tree over a single century — births, marriages, migrations and gaps in the archive.',
        'A statistical reading of one family tree over %s centuries — births, marriages, migrations and gaps in the archive.',
        $hero->centurySpan,
        SpelledNumber::for($hero->centurySpan),
    )
    : I18N::translate('A statistical reading of one family tree — births, marriages, migrations and gaps in the archive.');

// Eyebrow tag: tree title + earliest/latest birth decade range when
// both endpoints are known, mirroring the mockup's "Stammbaum X ·
// 1490er – 2020er" header. The decade-suffix is locale-specific —
// I18N::translate('%ss') resolves to "1490s" in English and "1490er"
// in German.
$eyebrow = $tree->title();

if ($hero->decadeFrom !== null && $hero->decadeTo !== null) {
    $eyebrow .= ' · ' . I18N::translate('%ss', (string) $hero->decadeFrom)
        . ' – ' . I18N::translate('%ss', (string) $hero->decadeTo);
}

// Dedicated translation context so the hero title can stay short
// ("Statistik") instead of inheriting webtrees-core's plural
// "Statistiken" for the generic "Statistics" string.
$titleText = I18N::translateContext('hero title', 'Statistics');
?>
<header class="wt-stat-hero">
    <div class="wt-stat-hero-inner">
        <div class="wt-stat-hero-meta">
            <p class="wt-stat-hero-eyebrow"><?php echo e($eyebrow); ?></p>
            <h1 class="wt-stat-hero-title"><?php echo e($titleText); ?></h1>
            <p class="wt-stat-hero-deck"><?php echo e($deckText); ?></p>
        </div>

        <div class="wt-stat-hero-stats">
            <div class="wt-stat-hero-stat">
                <div class="wt-stat-hero-stat-num"><?php echo e(I18N::number($hero->individuals)); ?></div>
                <div class="wt-stat-hero-stat-lab"><?php echo e(I18N::translate('Individuals')); ?></div>
            </div>

            <div class="wt-stat-hero-stat">
                <div class="wt-stat-hero-stat-num"><?php echo e(I18N::number($hero->families)); ?></div>
                <div class="wt-stat-hero-stat-lab"><?php echo e(I18N::translate('Families')); ?></div>
            </div>

            <div class="wt-stat-hero-stat">
                <div class="wt-stat-hero-stat-num"><?php echo e(I18N::number($generations)); ?></div>
                <div class="wt-stat-hero-stat-lab"><?php echo e(I18N::translate('Generations')); ?></div>
            </div>

            <div class="wt-stat-hero-stat">
                <?php if ($avgGenYears !== null) { ?>
                    <div class="wt-stat-hero-stat-num">
                        <?php echo e(I18N::number($avgGenYears, 1)); ?><span class="wt-stat-hero-stat-unit"><?php echo e(I18N::translate('yr')); ?></span>
                    </div>
                <?php } else { ?>
                    <div class="wt-stat-hero-stat-num wt-stat-hero-stat-empty">&mdash;</div>
                <?php } ?>
                <div class="wt-stat-hero-stat-lab"><?php echo e(I18N::translate('Avg. generation length')); ?></div>
            </div>

            <div class="wt-stat-hero-stat">
                <div class="wt-stat-hero-stat-num">
                    <?php echo e(I18N::number($hero->pedigreeCompleteness * 100, 1)); ?><span class="wt-stat-hero-stat-unit">%</span>
                </div>
                <div class="wt-stat-hero-stat-lab"><?php echo e(I18N::translate('Completeness')); ?></div>
            </div>

            <div class="wt-stat-hero-stat">
                <div class="wt-stat-hero-stat-num">
                    <?php echo e(I18N::number($hero->sourceCitationCoverage * 100, 1)); ?><span class="wt-stat-hero-stat-unit">%</span>
                </div>
                <div class="wt-stat-hero-stat-lab"><?php echo e(I18N::translate('Sourced')); ?></div>
            </div>
        </div>
    </div>

    <svg class="wt-stat-hero-ornament" viewBox="0 0 600 600" aria-hidden="true" focusable="false">
        <?php // 24 concentric circles, each one tier fainter — fades from 0.5 → ≈0.16. ?>
        <?php for ($i = 0; $i < 24; ++$i) { ?>
            <circle cx="300" cy="300"
                    r="<?php echo 20 + ($i * 12); ?>"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="0.5"
                    opacity="<?php echo number_format(0.5 - ($i * 0.015), 3, '.', ''); ?>"></circle>
        <?php } ?>
        <?php // 12 radial sun-rays at uniform 30° spacing. ?>
        <?php for ($i = 0; $i < 12; ++$i) {
            $angle = ($i / 12) * 2 * M_PI;
            ?>
            <line x1="300" y1="300"
                  x2="<?php echo 300 + (int) round(310 * cos($angle)); ?>"
                  y2="<?php echo 300 + (int) round(310 * sin($angle)); ?>"
                  stroke="currentColor"
                  stroke-width="0.4"
                  opacity="0.18"></line>
        <?php } ?>
    </svg>
</header>

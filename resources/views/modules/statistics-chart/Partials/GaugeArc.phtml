use MagicSunday\Webtrees\Statistic\Support\EmptyStatePlaceholder;
use MagicSunday\Webtrees\Statistic\Support\WidgetJson;

/**
 * GaugeArc widget shell. The SVG widget paints arc + headline `%`
 * value only — the textual `label`, `meta` and `caption` strings
 * render as sibling DOM elements UNDER the SVG so they sit clear
 * of the bignum read.
 *
 * @var float       $value   Percentage value 0–100
 * @var string      $accent  CSS color literal for the filled arc
 * @var string|null $label   Tiny eyebrow-style caption directly beneath the arc (e.g. "Lacy 1989")
 * @var string|null $meta    Optional mono caption (e.g. "326 of 2,156")
 * @var string|null $caption Optional muted caption rendered under meta
 */
$payload = ['value' => (float) $value];
$options = [
    'accent' => (string) ($accent ?? 'var(--wine)'),
];

$label   ??= null;
$meta    ??= null;
$caption ??= null;
?>
<div class="wt-stat-gauge-wrap">
    <div class="wt-stat-gauge-host"
         data-widget="gauge-arc"
         data-payload="<?php echo e(WidgetJson::encode($payload)); ?>"
         data-options="<?php echo e(WidgetJson::encode($options)); ?>"
         data-empty-message="<?php echo e(EmptyStatePlaceholder::defaultMessage()); ?>"></div>
    <?php if ($label !== null && $label !== '') { ?>
        <div class="wt-stat-gauge-label"><?php echo e((string) $label); ?></div>
    <?php } ?>
    <?php if ($meta !== null && $meta !== '') { ?>
        <div class="wt-stat-gauge-meta">
            <span class="wt-stat-gauge-meta-line wt-stat-mono"><?php echo e($meta); ?></span>
            <?php if ($caption !== null && $caption !== '') { ?>
                <span class="wt-stat-gauge-meta-cap"><?php echo e($caption); ?></span>
            <?php } ?>
        </div>
    <?php } ?>
</div>

use MagicSunday\Webtrees\Statistic\Support\WidgetJson;

/**
 * GaugeArc widget shell. The payload is a single percentage value
 * (0–100); the consumer-rendered meta + caption strings live
 * outside the SVG so the gauge stays a pure chart-lib widget.
 *
 * @var float       $value   Percentage value 0–100
 * @var string      $accent  CSS color literal for the filled arc
 * @var string      $label   Tiny caption underneath the value (e.g. "Lacy 1989")
 * @var string|null $meta    Optional mono caption rendered below the SVG (e.g. "326 of 2,156 individuals")
 * @var string|null $caption Optional muted caption rendered under meta
 */
$payload = ['value' => (float) $value];
$options = [
    'accent' => (string) ($accent ?? 'var(--wine)'),
    'label'  => (string) ($label ?? ''),
];

$meta    ??= null;
$caption ??= null;
?>
<div class="wt-stat-gauge-wrap">
    <div class="wt-stat-gauge-host"
         data-widget="gauge-arc"
         data-payload="<?php echo e(WidgetJson::encode($payload)); ?>"
         data-options="<?php echo e(WidgetJson::encode($options)); ?>"></div>
    <?php if ($meta !== null && $meta !== '') { ?>
        <div class="wt-stat-gauge-meta">
            <span class="wt-stat-gauge-meta-line wt-stat-mono"><?php echo e($meta); ?></span>
            <?php if ($caption !== null && $caption !== '') { ?>
                <span class="wt-stat-gauge-meta-cap"><?php echo e($caption); ?></span>
            <?php } ?>
        </div>
    <?php } ?>
</div>

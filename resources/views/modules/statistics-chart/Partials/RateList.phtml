use Fisharebest\Webtrees\I18N;

/**
 * Renders one row per `{label, value, total}` entry showing the value as
 * an absolute count, a fraction of the total, and a horizontal progress
 * bar coloured via the Tree Health palette tokens.
 *
 * @var array<int, array{label: string, value: int, total: int}> $data  Rate-style rows
 * @var string                                                   $class CSS class applied to every progress-bar so the gradient theme tokens scope correctly
 */
?>
<div class="wt-rate-list">
    <table class="progress-bar-table">
        <tbody>
            <?php foreach ($data as $entry) { ?>
                <?php
                    $value = $entry['value'];
                $total     = $entry['total'];
                $percent   = ($total > 0) ? ($value * 100.0 / $total) : 0.0;
                $caption   = ($total > 0)
                        ? I18N::translate('%1$s of %2$s (%3$s%%)', I18N::number($value), I18N::number($total), I18N::number((int) round($percent)))
                        : I18N::translate('no data');
                ?>
                <tr>
                    <td class="label"><small><?php echo e($entry['label']); ?></small></td>
                    <td class="value"><small><?php echo $caption; ?></small></td>
                </tr>
                <tr>
                    <td colspan="2" class="pb-2">
                        <div class="progress" role="progressbar"
                             aria-label="<?php echo e($entry['label']); ?>"
                             aria-valuenow="<?php echo $percent; ?>"
                             aria-valuemin="0"
                             aria-valuemax="100"
                             style="height: 16px;"
                        >
                            <div class="progress-bar <?php echo e($class); ?>" style="width: calc(16px + <?php echo $percent; ?>%); background-color: color-mix(in srgb, var(--bs-progress-label-gradient-start), var(--bs-progress-label-gradient-end) <?php echo $percent; ?>%)"></div>
                        </div>
                    </td>
                </tr>
            <?php } ?>
        </tbody>
    </table>
</div>

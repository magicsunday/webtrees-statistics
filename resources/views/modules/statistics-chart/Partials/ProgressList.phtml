declare(strict_types=1);

use Fisharebest\Webtrees\Tree;

/**
 * @var Tree               $tree
 * @var array<string, int> $data
 * @var string             $class
 * @var string             $suffix Optional unit appended to every value cell (e.g. "%")
 */
$suffix ??= '';
?>
<div class="wt-births-list">
    <table class="progress-bar-table">
        <tbody>
            <?php $maximum = ($data === []) ? 0 : max($data); ?>
            <?php foreach ($data as $key => $value) { ?>
                <?php $width = ($maximum > 0) ? ($value * 100.0 / $maximum) : 0.0; ?>

                <tr>
                    <td class="label"><small><?php echo e($key); ?></small></td>
                    <td class="value"><small><?php echo e($value . $suffix); ?></small></td>
                </tr>
                <tr>
                    <td colspan="2" class="pb-2">
                        <div class="progress" role="progressbar"
                             aria-label="<?php echo e($key); ?>"
                             aria-valuenow="<?php echo $width; ?>"
                             aria-valuemin="0"
                             aria-valuemax="100"
                             style="height: 16px;"
                        >
                            <div class="progress-bar <?php echo e($class); ?>" style="width: calc(16px + <?php echo $width; ?>%); background-color: color-mix(in srgb, var(--bs-progress-label-gradient-start), var(--bs-progress-label-gradient-end) <?php echo $width; ?>%)"></div>
                        </div>
                    </td>
                </tr>
            <?php } ?>
        </tbody>
    </table>
</div>

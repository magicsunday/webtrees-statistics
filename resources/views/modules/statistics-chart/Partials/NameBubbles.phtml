use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Support\WidgetJson;

/**
 * Name-bubble widget shell. Emits a `data-widget="name-bubbles"`
 * marker carrying the payload as JSON; the dispatcher
 * (`renderWidgets` in `resources/js/modules/index.js`) hands it off
 * to the `name-bubbles` client-side renderer which computes the
 * circle-pack layout and inserts the SVG.
 *
 * @var array<int, array{label: string, value: int}> $data   Top-N name → count rows
 * @var string                                       $accent CSS color literal or `var(--...)` reference for bubble fill base
 */
$payload = [];

foreach ($data as $row) {
    $payload[] = ['label' => (string) ($row['label'] ?? ''), 'value' => (int) ($row['value'] ?? 0)];
}

if ($payload === []) {
    echo '<p class="text-muted text-center mb-0">' . e(I18N::translate('No names recorded yet.')) . '</p>';

    return;
}

$options = ['accent' => (string) $accent];
?>
<div class="wt-stat-bubble-host"
     data-widget="name-bubbles"
     data-payload="<?php echo e(WidgetJson::encode($payload)); ?>"
     data-options="<?php echo e(WidgetJson::encode($options)); ?>"></div>

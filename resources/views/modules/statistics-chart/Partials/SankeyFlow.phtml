use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\Statistic\Model\Dto\Sankey\MigrationFlowsPayload;
use MagicSunday\Webtrees\Statistic\Support\WidgetJson;

/**
 * @var string                $identifier Host element id
 * @var MigrationFlowsPayload $data       Sankey payload built by Statistic::getMigrationFlows() — serialises to JSON via JsonSerializable
 * @var int|null              $height     Optional viewport height (defaults to 360)
 */
$height ??= 360;

// chart-lib sankey-flow reads `options.i18n.totalSingular / totalPlural`
// to localise the per-link tooltip count ("3 individuals" → "3 Personen").
// Curly-brace {count} placeholder instead of sprintf %s — see the
// StreamGraph partial for the rationale.
$sankeyI18n = [
    'totalSingular' => I18N::translate('{count} individual'),
    'totalPlural'   => I18N::translate('{count} individuals'),
];
?>
<div class="wt-sankey-container">
    <div id="<?php echo e($identifier); ?>"
         class="wt-sankey-host"
         data-widget="sankey-flow"
         data-payload="<?php echo e(WidgetJson::encode($data)); ?>"
         data-options="<?php echo e(WidgetJson::encode(['height' => $height, 'i18n' => $sankeyI18n])); ?>"
         data-empty-message="<?php echo e(I18N::translate('No country-to-country movements recorded yet.')); ?>"
    ></div>
</div>

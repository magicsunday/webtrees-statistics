use MagicSunday\Webtrees\Statistic\Support\EmptyStatePlaceholder;
use MagicSunday\Webtrees\Statistic\Support\WidgetJson;

/**
 * @var string                                                                                                $identifier  Host element id
 * @var array<int, array{label: string, value: int, class?: string, tooltip?: string, tooltipLabel?: string}> $data Bar rows in display order
 * @var int|null                                                                                              $height       Optional viewport height (defaults to 240)
 * @var string|null                                                                                           $orientation  "vertical" (default) or "horizontal"
 * @var bool|null                                                                                             $brush        Enable d3-brush selection (default false)
 * @var string|null                                                                                           $ariaLabel    Accessible label on the host svg
 */
$height      ??= 240;
$orientation ??= 'vertical';
$brush       ??= false;

// Treat an all-zero payload as empty — callers regularly pre-build
// every band with `value => 0` (e.g. distinct-places-per-individual
// buckets, divorce-by-decade groups) and the chart-lib widget would
// otherwise render a row of invisible bars instead of the standard
// placeholder.
if (($data === []) || (array_sum(array_column($data, 'value')) <= 0)) {
    echo EmptyStatePlaceholder::render();

    return;
}
?>
<div class="wt-bar-chart-container">
    <div id="<?php echo e($identifier); ?>"
         class="wt-bar-chart-host"
         data-widget="bar-chart"
         data-payload="<?php echo e(WidgetJson::encode($data)); ?>"
         data-options="<?php echo e(WidgetJson::encode([
             'height'      => $height,
             'orientation' => $orientation,
             'brush'       => $brush,
             'ariaLabel'   => $ariaLabel ?? null,
         ])); ?>"
         data-empty-message="<?php echo e(EmptyStatePlaceholder::defaultMessage()); ?>"
    ></div>
</div>

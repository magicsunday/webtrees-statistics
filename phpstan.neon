includes:
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-strict-rules/rules.neon
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-deprecation-rules/rules.neon
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-phpunit/extension.neon
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-phpunit/rules.neon
    - %currentWorkingDirectory%/.build/vendor/phpat/phpat/extension.neon

parameters:
    # You can currently choose from 11 levels (0 is the loosest and 10 is the strictest).
    level: max

    # PHP Version to check against (PHP 8.3 as minimum target)
    phpVersion: 80300

    tmpDir: %currentWorkingDirectory%/.build/cache/.phpstan.cache

    paths:
        - %currentWorkingDirectory%/src/
        - %currentWorkingDirectory%/tests/

    fileExtensions:
        - php

    excludePaths:
        - %currentWorkingDirectory%/.build/

    # JetBrains' PHP stub for ext-calendar still spells gregoriantojd
    # as PascalCase (`GregorianToJD`), while the official PHP manual
    # at https://www.php.net/manual/en/function.gregoriantojd.php has
    # been canonical lowercase for years. PHPStan inherits the stale
    # PascalCase from the stub and raises `function.nameCase` for
    # every call that uses the manual-canonical lowercase form.
    # Suppress just this one mismatch until JetBrains fixes the stub.
    ignoreErrors:
        -
            identifier: function.nameCase
            path: src/Repository/LifeSpanRepository.php

        # illuminate 13.13+ narrowed the raw-SQL builder surface to
        # `literal-string`: `Expression::__construct()`, `Builder::selectRaw()`
        # and `Builder::orderByRaw()` now reject runtime-built strings. Our
        # aggregate fragments deliberately embed the connection table prefix
        # (`DB::connection()->getTablePrefix()`) and the physical table name so
        # the MIN/MAX/SUM references the actual prefixed table — trusted, but
        # provably non-literal. Released webtrees still ships illuminate 12.x
        # without the narrowing; this only fires against the `dev-main` probe.
        -
            message: '#expects (literal-string|TValue of float\|int\|literal-string)#'
            identifier: argument.type
            paths:
                - src/Repository/FamilyRankingRepository.php
                - src/Repository/LifeSpanRepository.php
                - src/Support/Database/DateAggregate.php

        # Same root cause surfacing on the `@return Expression<…>` generics: the
        # illuminate 13 Expression template bound became
        # `float|int|literal-string`, so a runtime-string Expression no longer
        # satisfies the documented generic argument.
        -
            message: '#generic type Illuminate.+Expression#'
            identifier: generics.notSubtype
            paths:
                - src/Repository/LifeSpanRepository.php
                - src/Support/Database/DateAggregate.php

        -
            message: '#should return Illuminate.+Expression<non-falsy-string>#'
            identifier: return.type
            path: src/Support/Database/DateAggregate.php

    phpat:
        show_rule_names: true

services:
    -
        class: MagicSunday\Webtrees\Statistic\Test\Architecture\ArchitectureTest
        tags:
            - phpat.test
